## Обработка ошибок

```csharp
// ✅ Кастомные исключения для доменных ошибок
public class DomainException(string message) : Exception(message);
public class NotFoundException(string message) : DomainException(message);
public class ValidationException(IEnumerable<string> errors)
    : DomainException("Ошибка валидации")
{
    public IReadOnlyList<string> Errors { get; } = errors.ToList();
}

// ✅ Глобальный обработчик через Middleware или IExceptionHandler (.NET 8+)
// ✅ ProblemDetails для API ответов об ошибках
// ✅ Логировать с контекстом через structured logging
logger.LogError(ex, "Ошибка при создании заказа для клиента {CustomerId}", customerId);
```

