<Page x:Class="DarkBot.Net.Presentation.Views.Config.Pages.ConfigCollectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:DarkBot.Net.Presentation.Controls"
      xmlns:loc="clr-namespace:DarkBot.Net.Presentation.Resources"
      Title="{x:Static loc:UiStrings.ConfigCollect_PageTitle}"
      xml:lang="ru-RU">

  <Page.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Page.Resources>

  <Grid Style="{StaticResource WpfUiViewHostGrid}">
    <controls:ConfigCollectSectionControl x:Name="CollectSection" />
  </Grid>
</Page>
