<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Controls.Main.StatsPanelControl"
             x:TypeArguments="vm:StatsPanelViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
             xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels.Main"
             xmlns:loc="clr-namespace:DarkBot.Net.Presentation.Resources"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:StatsPanelViewModel, IsDesignTimeCreatable=True}"
             d:DesignWidth="1060"
             d:DesignHeight="48">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <UniformGrid Columns="4">
    <StackPanel Margin="0,0,16,0">
      <ui:TextBlock Style="{StaticResource MainMetricCaption}"
                    Text="{x:Static loc:UiStrings.Main_Stats_Credits}" />
      <ui:TextBlock Style="{StaticResource MainMetricValue}"
                    Text="{Binding Credits, StringFormat=N0}" />
    </StackPanel>

    <StackPanel Margin="0,0,16,0">
      <ui:TextBlock Style="{StaticResource MainMetricCaption}"
                    Text="{x:Static loc:UiStrings.Main_Stats_Uridium}" />
      <ui:TextBlock Style="{StaticResource MainMetricValue}"
                    Text="{Binding Uridium, StringFormat=N0}" />
    </StackPanel>

    <StackPanel Margin="0,0,16,0">
      <ui:TextBlock Style="{StaticResource MainMetricCaption}"
                    Text="{x:Static loc:UiStrings.Main_Stats_Experience}" />
      <ui:TextBlock Style="{StaticResource MainMetricValue}"
                    Text="{Binding Experience, StringFormat=N0}" />
    </StackPanel>

    <StackPanel>
      <ui:TextBlock Style="{StaticResource MainMetricCaption}"
                    Text="{x:Static loc:UiStrings.Main_Stats_Honor}" />
      <ui:TextBlock Style="{StaticResource MainMetricValue}"
                    Text="{Binding Honor, StringFormat=N0}" />
    </StackPanel>
  </UniformGrid>
</rxui:ReactiveUserControl>
