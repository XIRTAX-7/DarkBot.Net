<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Views.Main.MainView"
        x:TypeArguments="vm:MainWindowViewModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
        xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels.Main"
        xmlns:loc="clr-namespace:DarkBot.Net.Presentation.Resources"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:mainControls="clr-namespace:DarkBot.Net.Presentation.Controls.Main"
        xmlns:mapCanvas="clr-namespace:DarkBot.Net.Presentation.Controls.Main.MapCanvas"
        mc:Ignorable="d"
        xml:lang="ru-RU"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=True}"
        d:DesignWidth="1280"
        d:DesignHeight="820">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Style="{StaticResource WpfUiViewHostGrid}" Margin="20,12,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="395" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:Card Grid.Row="0" Margin="0" Padding="0">
            <Border Style="{StaticResource MainCommandBarBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Margin="0,0,14,0">
                        <Border Style="{StaticResource MainBrandMarkBorder}" Margin="0,0,10,0">
                            <ui:SymbolIcon Symbol="Shield24"
                             FontSize="18"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                        </Border>
                        <ui:TextBlock FontTypography="Subtitle"
                          VerticalAlignment="Center"
                          Text="DarkBot.Net" />
                    </StackPanel>

                    <Border Grid.Column="1"
                  Style="{StaticResource MainStatusPillBorder}"
                  Margin="0,0,10,0"
                  MinWidth="220">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Ellipse Grid.Column="0"
                       Style="{StaticResource MainStatusDot}"
                       Margin="0,0,8,0" />
                            <ui:TextBlock Grid.Column="1"
                            FontTypography="Body"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="{Binding StatusLine, FallbackValue=Готов, TargetNullValue=Готов}"
                            TextTrimming="CharacterEllipsis"
                            VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                  Style="{StaticResource MainStatusPillBorder}"
                  Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:TextBlock Style="{StaticResource MainMetricCaption}"
                            Text="Конфиг"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0" />
                            <ComboBox Style="{StaticResource MainToolbarComboBox}"
                        SelectedIndex="0"
                        ToolTip="Визуальный слот под быстрое переключение конфигурации">
                                <ComboBoxItem Content="Конфиг 1" />
                                <ComboBoxItem Content="Конфиг 2" />
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ui:Button x:Name="RestartClientButton"
                                   Style="{StaticResource MainCommandButton}"
                                   Appearance="Transparent"
                                   Content="Клиент"
                                   ToolTip="{x:Static loc:UiStrings.Main_RestartClientTooltip}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="ArrowClockwise24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <mainControls:BotRunToggleButton x:Name="ToggleBotButton" />
                        <ui:Button x:Name="OpenConfigButton"
                                   Style="{StaticResource MainCommandButton}"
                                   Appearance="Secondary"
                                   Content="{x:Static loc:UiStrings.Main_ConfigButton}" />
                        <ui:Button x:Name="OpenLoginButton"
                                   Style="{StaticResource MainCommandButtonLast}"
                                   Appearance="Danger"
                                   Content="{x:Static loc:UiStrings.Main_LoginButton}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="SignOut24" Filled="True" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Border>
        </ui:Card>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Style="{StaticResource WpfUiControlSurfaceBorder}"
                MinHeight="395">
            <mapCanvas:MapCanvasControl x:Name="MapCanvas"
                                        VerticalAlignment="Stretch"
                                        HorizontalAlignment="Stretch"
                                        Snapshot="{Binding Snapshot}" />
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ui:Card Grid.Row="0" Margin="0,0,0,8" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource MainCompactSurfaceBorder}"
                            Margin="0,0,4,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Shield24" FontSize="14" Margin="0,0,6,0" />
                                    <ui:TextBlock Style="{StaticResource MainCompactSectionLabel}" Text="Корабль" />
                                </StackPanel>

                                <ui:TextBlock Grid.Column="1"
                                              Style="{StaticResource MainCompactMetricCaption}"
                                              HorizontalAlignment="Right"
                                              Text="{Binding Snapshot.Map.Hero.Configuration}"
                                              TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <ui:TextBlock Style="{StaticResource MainCompactMetricCaption}"
                                          Margin="0,0,0,4"
                                          Text="{Binding Snapshot.Map.MapName, FallbackValue=Загрузка, TargetNullValue=Загрузка}"
                                          TextTrimming="CharacterEllipsis" />

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MainCompactMetricCaption}" Text="HP" />
                                <ProgressBar Grid.Row="0"
                                             Grid.Column="1"
                                             Height="4"
                                             Maximum="{Binding Snapshot.Map.Hero.MaxHp}"
                                             Value="{Binding Snapshot.Map.Hero.Hp}"
                                             VerticalAlignment="Center" />
                                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Hero.Hp, StringFormat=N0}" />
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="/" />
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Hero.MaxHp, StringFormat=N0}" />
                                </StackPanel>

                                <ui:TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MainCompactMetricCaption}" Text="Щит" Margin="0,4,0,0" />
                                <ProgressBar Grid.Row="1"
                                             Grid.Column="1"
                                             Height="4"
                                             Maximum="{Binding Snapshot.Map.Hero.MaxShield}"
                                             Value="{Binding Snapshot.Map.Hero.Shield}"
                                             VerticalAlignment="Center"
                                             Margin="0,4,0,0" />
                                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="6,4,0,0">
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Hero.Shield, StringFormat=N0}" />
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="/" />
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Hero.MaxShield, StringFormat=N0}" />
                                </StackPanel>

                                <ui:TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MainCompactMetricCaption}" Text="Nano" Margin="0,4,0,0" />
                                <ProgressBar Grid.Row="2"
                                             Grid.Column="1"
                                             Height="4"
                                             Maximum="{Binding Snapshot.Map.Hero.MaxNano}"
                                             Value="{Binding Snapshot.Map.Hero.Nano}"
                                             VerticalAlignment="Center"
                                             Margin="0,4,0,0" />
                                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" Margin="6,4,0,0">
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Hero.Nano, StringFormat=N0}" />
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="/" />
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Hero.MaxNano, StringFormat=N0}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,6,0,0">
                                <ui:TextBlock Style="{StaticResource MainCompactMetricCaption}" Text="Позиция" />
                                <StackPanel Orientation="Horizontal">
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Hero.X, StringFormat=N0}" />
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text=", " />
                                    <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Hero.Y, StringFormat=N0}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource MainCompactSurfaceBorder}"
                            Margin="4,0,4,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <ui:SymbolIcon Symbol="AnimalCat24" FontSize="14" Margin="0,0,6,0" />
                                <ui:TextBlock Style="{StaticResource MainCompactSectionLabel}" Text="PET" />
                            </StackPanel>

                            <ui:TextBlock Style="{StaticResource MainCompactMetricCaption}" Text="HP" />
                            <ProgressBar Height="4"
                                         Maximum="{Binding Snapshot.Map.Pet.MaxHp, TargetNullValue=0}"
                                         Value="{Binding Snapshot.Map.Pet.Hp, TargetNullValue=0}"
                                         Margin="0,2,0,4" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Pet.Hp, TargetNullValue=0, FallbackValue=0, StringFormat=N0}" />
                                <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="/" />
                                <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Pet.MaxHp, TargetNullValue=0, FallbackValue=0, StringFormat=N0}" />
                            </StackPanel>

                            <ui:TextBlock Style="{StaticResource MainCompactMetricCaption}" Text="Топливо" />
                            <ProgressBar Height="4"
                                         Maximum="{Binding Snapshot.Map.Pet.MaxFuel, TargetNullValue=0}"
                                         Value="{Binding Snapshot.Map.Pet.Fuel, TargetNullValue=0}"
                                         Margin="0,2,0,0" />
                            <StackPanel Orientation="Horizontal">
                                <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Pet.Fuel, TargetNullValue=0, FallbackValue=0, StringFormat=N0}" />
                                <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="/" />
                                <ui:TextBlock Style="{StaticResource MainCompactMetricValue}" Text="{Binding Snapshot.Map.Pet.MaxFuel, TargetNullValue=0, FallbackValue=0, StringFormat=N0}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource MainCompactSurfaceBorder}"
                            Margin="4,0,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <ui:SymbolIcon Symbol="PeopleTeam24" FontSize="14" Margin="0,0,6,0" />
                                <ui:TextBlock Style="{StaticResource MainCompactSectionLabel}" Text="Группа" />
                                <ui:TextBlock Style="{StaticResource MainCompactMetricValue}"
                                              Margin="6,0,0,0"
                                              Text="{Binding Snapshot.Map.Overlay.GroupMembers.Count, StringFormat={}{0} чел.}" />
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding Snapshot.Map.Overlay.GroupMembers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <ui:TextBlock Text="{Binding DisplayText}"
                                                          Style="{StaticResource MainCompactMetricCaption}"
                                                          TextTrimming="CharacterEllipsis" />
                                            <ui:TextBlock Grid.Column="1"
                                                          Style="{StaticResource MainCompactMetricValue}"
                                                          Margin="6,0,0,0"
                                                          Text="{Binding Hp, StringFormat=N0}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </ui:Card>

            <mainControls:StatsPanelControl Grid.Row="1"
                                            x:Name="StatsPanel" />
        </Grid>
    </Grid>
</rxui:ReactiveUserControl>
