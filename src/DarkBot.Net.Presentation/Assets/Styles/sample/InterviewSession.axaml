<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════════════
         Interview Session — все стили overlay и зон сессии
         Цвета: App.axaml → ThemeDictionaries (Interview*)
         ══════════════════════════════════════════════════════════════ -->

    <!-- Корневая overlay-панель -->
    <Style Selector="Border.interview-overlay">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Background" Value="{DynamicResource InterviewOverlayBackground}" />
        <Setter Property="BoxShadow" Value="0 8 32 -4 #40000000" />
    </Style>

    <!-- ═══ Header ═══ -->
    <Style Selector="Grid.interview-header">
        <Setter Property="Height" Value="48" />
        <Setter Property="Background" Value="{DynamicResource InterviewHeaderBackground}" />
    </Style>

    <Style Selector="StackPanel.interview-header-left">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="8" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="12,0" />
    </Style>

    <Style Selector="Canvas.interview-indicator-canvas">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
    </Style>

    <Style Selector="Ellipse.interview-indicator-ring">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="Canvas.Left" Value="0" />
        <Setter Property="Canvas.Top" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="50%,50%" />
    </Style>

    <Style Selector="Ellipse.interview-indicator-ring.recording">
        <Setter Property="Stroke" Value="{DynamicResource InterviewHeaderStateRecordingForeground}" />
    </Style>

    <Style Selector="Ellipse.interview-indicator-ring.finished">
        <Setter Property="Stroke" Value="{DynamicResource InterviewHeaderStateFinishedForeground}" />
    </Style>

    <Style Selector="Ellipse.interview-indicator-ring.idle">
        <Setter Property="Stroke" Value="{DynamicResource InterviewHeaderStateIdleForeground}" />
    </Style>

    <Style Selector="Ellipse.interview-indicator-dot">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Canvas.Left" Value="8" />
        <Setter Property="Canvas.Top" Value="8" />
    </Style>

    <Style Selector="Ellipse.interview-indicator-dot.recording">
        <Setter Property="Fill" Value="{DynamicResource InterviewHeaderStateRecordingForeground}" />
    </Style>

    <Style Selector="Ellipse.interview-indicator-dot.finished">
        <Setter Property="Fill" Value="{DynamicResource InterviewHeaderStateFinishedForeground}" />
    </Style>

    <Style Selector="Ellipse.interview-indicator-dot.idle">
        <Setter Property="Fill" Value="{DynamicResource InterviewHeaderStateIdleForeground}" />
    </Style>

    <Style Selector="Border.interview-state-badge">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="8,4,10,4" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.interview-state-badge.recording">
        <Setter Property="Background" Value="{DynamicResource InterviewHeaderStateRecordingBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewHeaderStateRecordingForeground}" />
    </Style>

    <Style Selector="Border.interview-state-badge.finished">
        <Setter Property="Background" Value="{DynamicResource InterviewHeaderStateFinishedBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewHeaderStateFinishedForeground}" />
    </Style>

    <Style Selector="Border.interview-state-badge.idle">
        <Setter Property="Background" Value="{DynamicResource InterviewHeaderStateIdleBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewHeaderStateIdleForeground}" />
    </Style>

    <Style Selector="StackPanel.interview-state-badge-content">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="5" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Ellipse.interview-state-dot">
        <Setter Property="Width" Value="6" />
        <Setter Property="Height" Value="6" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Ellipse.interview-state-dot.recording">
        <Setter Property="Fill" Value="{DynamicResource InterviewHeaderStateRecordingForeground}" />
    </Style>

    <Style Selector="Ellipse.interview-state-dot.finished">
        <Setter Property="Fill" Value="{DynamicResource InterviewHeaderStateFinishedForeground}" />
    </Style>

    <Style Selector="Ellipse.interview-state-dot.idle">
        <Setter Property="Fill" Value="{DynamicResource InterviewHeaderStateIdleForeground}" />
    </Style>

    <Style Selector="Path.interview-state-check">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Stretch" Value="None" />
        <Setter Property="Width" Value="7" />
        <Setter Property="Height" Value="7" />
        <Setter Property="Data" Value="M0,4 L2.5,6.5 L7,1" />
    </Style>

    <Style Selector="Path.interview-state-check.recording">
        <Setter Property="Fill" Value="{DynamicResource InterviewHeaderStateRecordingForeground}" />
    </Style>

    <Style Selector="Path.interview-state-check.finished">
        <Setter Property="Fill" Value="{DynamicResource InterviewHeaderStateFinishedForeground}" />
    </Style>

    <Style Selector="Path.interview-state-check.idle">
        <Setter Property="Fill" Value="{DynamicResource InterviewHeaderStateIdleForeground}" />
    </Style>

    <Style Selector="TextBlock.interview-state-badge-text">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LetterSpacing" Value="0.5" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.interview-state-badge-text.recording">
        <Setter Property="Foreground" Value="{DynamicResource InterviewHeaderStateRecordingForeground}" />
    </Style>

    <Style Selector="TextBlock.interview-state-badge-text.finished">
        <Setter Property="Foreground" Value="{DynamicResource InterviewHeaderStateFinishedForeground}" />
    </Style>

    <Style Selector="TextBlock.interview-state-badge-text.idle">
        <Setter Property="Foreground" Value="{DynamicResource InterviewHeaderStateIdleForeground}" />
    </Style>

    <Style Selector="TextBlock.interview-timer">
        <Setter Property="FontFamily" Value="JetBrains Mono, Consolas, Courier New, monospace" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewHeaderForeground}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.interview-vacancy-context">
        <Setter Property="Foreground" Value="{DynamicResource InterviewTopicBadgeForeground}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="12,0" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="MaxWidth" Value="260" />
    </Style>

    <!-- ═══ Zone cards ═══ -->
    <Style Selector="Border.interview-zone-card">
        <Setter Property="Margin" Value="8,6,8,0" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.interview-zone-card.question">
        <Setter Property="MaxHeight" Value="130" />
        <Setter Property="Background" Value="{DynamicResource InterviewQuestionBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewQuestionBorder}" />
    </Style>

    <Style Selector="Border.interview-zone-card.transcription">
        <Setter Property="MaxHeight" Value="120" />
        <Setter Property="Background" Value="{DynamicResource InterviewAnswerBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewAnswerBorder}" />
    </Style>

    <Style Selector="Border.interview-zone-card.ai-answer">
        <Setter Property="Background" Value="{DynamicResource InterviewFeedbackBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewFeedbackBorder}" />
    </Style>

    <Style Selector="Border.interview-zone-card.screenshots">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{DynamicResource InterviewAnswerBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewAnswerBorder}" />
    </Style>

    <Style Selector="Grid.interview-zone-layout">
        <Setter Property="RowSpacing" Value="7" />
    </Style>

    <Style Selector="Grid.interview-zone-layout.ai-answer">
        <Setter Property="RowSpacing" Value="8" />
    </Style>

    <Style Selector="Grid.interview-zone-header">
        <Setter Property="ColumnSpacing" Value="8" />
    </Style>

    <!-- ═══ Typography ═══ -->
    <Style Selector="TextBlock.interview-section-label">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LetterSpacing" Value="1.2" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewQuestionLabel}" />
    </Style>

    <Style Selector="TextBlock.interview-section-label.accent">
        <Setter Property="Foreground" Value="{DynamicResource InterviewTopicBadgeForeground}" />
    </Style>

    <Style Selector="TextBlock.interview-status-text">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewHeaderSubtext}" />
        <Setter Property="Opacity" Value="0.75" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.interview-placeholder">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewAnswerPlaceholder}" />
        <Setter Property="Opacity" Value="0.8" />
    </Style>

    <Style Selector="TextBlock.interview-body-text">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewQuestionForeground}" />
    </Style>

    <Style Selector="TextBlock.interview-body-text.waiting">
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="FontStyle" Value="Italic" />
    </Style>

    <Style Selector="TextBlock.interview-body-text.muted">
        <Setter Property="Opacity" Value="0.85" />
    </Style>

    <Style Selector="TextBlock.interview-body-text.transcription">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewHeaderForeground}" />
        <Setter Property="Opacity" Value="0.86" />
    </Style>

    <Style Selector="Border.interview-listening-dot">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="{DynamicResource InterviewMicRecordingBackground}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.interview-thinking-badge">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="Background" Value="{DynamicResource InterviewTopicBadgeBackground}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.interview-thinking-badge TextBlock">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewTopicBadgeForeground}" />
        <Setter Property="LetterSpacing" Value="0.8" />
    </Style>

    <Style Selector="Border.interview-answer-inner">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Background" Value="{DynamicResource InterviewAnswerBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewAnswerBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.interview-answer-inner TextBlock">
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewHeaderForeground}" />
    </Style>

    <!-- ═══ Control bar ═══ -->
    <Style Selector="Border.interview-control-bar">
        <Setter Property="Margin" Value="8,6,8,8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource InterviewHeaderBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewHeaderBorder}" />
    </Style>

    <Style Selector="Grid.interview-control-bar-layout">
        <Setter Property="ColumnSpacing" Value="12" />
    </Style>

    <Style Selector="ToggleSwitch.interview-mode-toggle">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="ScrollViewer.interview-zone-scroll">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style Selector="ScrollViewer.screenshots-scroll">
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style Selector="StackPanel.interview-hotkeys">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="8" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="StackPanel.hotkey-badge-content">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="8" />
    </Style>

    <Style Selector="TextBlock.hotkey-badge-caption">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.hotkey-chip">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Background" Value="{DynamicResource InterviewAnswerBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewAnswerBorder}" />
    </Style>

    <Style Selector="Border.hotkey-chip TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewHeaderForeground}" />
    </Style>

    <Style Selector="Border.hotkey-chip.accent">
        <Setter Property="Background" Value="{DynamicResource InterviewMicProcessingBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewMicProcessingForeground}" />
    </Style>

    <Style Selector="Border.hotkey-chip.accent TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource InterviewMicProcessingForeground}" />
    </Style>

    <Style Selector="Button.hotkey-badge">
        <Setter Property="Background" Value="{DynamicResource InterviewNavButtonBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewHeaderBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewNavButtonForeground}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background"
                                 Duration="0:0:0.12" />
                <BrushTransition Property="BorderBrush"
                                 Duration="0:0:0.12" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.hotkey-badge:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewQuestionLabel}" />
        <Setter Property="Background" Value="{DynamicResource InterviewNavButtonHover}" />
    </Style>

    <Style Selector="Button.hotkey-badge.accent">
        <Setter Property="BorderBrush" Value="{DynamicResource InterviewMicProcessingForeground}" />
    </Style>

    <Style Selector="Button.session-btn">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewNavPrimaryForeground}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource InterviewSessionStartBackground}" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity"
                                  Duration="0:0:0.12" />
                <BrushTransition Property="Background"
                                 Duration="0:0:0.12" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.session-btn.recording">
        <Setter Property="Background" Value="{DynamicResource InterviewSessionStopBackground}" />
    </Style>

    <Style Selector="Button.session-btn:pointerover">
        <Setter Property="Opacity" Value="0.85" />
    </Style>

    <Style Selector="StackPanel.session-btn-content">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="6" />
    </Style>

    <Style Selector="StackPanel.session-btn-content TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ═══ Анимации ═══
         1) KeyFrame + Style.Animations — loop / enter-exit (pulse, gallery, cards)
         2) Transitions — hover/focus на кнопках (см. hotkey-badge, session-btn)
         3) Classes.{state} — триггер из VM (recording/finished/idle, hiding, listening)
         Длительности/easing: Themes/AnimationDurations.cs, AnimationEasings.cs ({x:Static})
         ScaleTransform: RenderTransform обязателен на элементе (см. Header View).
         ═══ -->

    <!-- Pulse-кольцо: класс pulse-ring включается только при IsRecording -->
    <Style Selector="Ellipse.pulse-ring">
        <Style.Animations>
            <Animation Duration="0:0:1.6"
                       IterationCount="INFINITE"
                       FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="ScaleTransform.ScaleX" Value="1" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1" />
                    <Setter Property="Opacity" Value="0.8" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="ScaleTransform.ScaleX" Value="1.6" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1.6" />
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Индикатор «слушаем» в транскрибации -->
    <Style Selector="Border.interview-listening-dot.listening">
        <Style.Animations>
            <Animation Duration="0:0:1.1"
                       IterationCount="INFINITE"
                       FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Opacity" Value="0.35" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ═══ Screenshots: enter / exit по классу hiding ═══ -->
    <Style Selector="Border.screenshots-gallery">
        <Setter Property="Opacity" Value="1" />
        <Style.Animations>
            <Animation Duration="0:0:0.14"
                       FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Border.screenshots-gallery.hiding">
        <Setter Property="Opacity" Value="0" />
        <Style.Animations>
            <Animation Duration="0:0:0.14"
                       FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="StackPanel.screenshots-strip">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="6" />
    </Style>

    <Style Selector="Grid.screenshot-thumb">
        <Setter Property="Width" Value="60" />
        <Setter Property="Height" Value="45" />
    </Style>

    <Style Selector="Border.screenshot-card">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Background" Value="{DynamicResource InterviewMicIdleBackground}" />
        <Style.Animations>
            <Animation Duration="0:0:0.14"
                       FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Border.screenshot-card Image">
        <Setter Property="Stretch" Value="UniformToFill" />
    </Style>

    <Style Selector="Border.screenshot-counter-wrap">
        <Setter Property="Padding" Value="10,0,2,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="TextBlock.screenshot-counter">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource InterviewScreenshotCounterForeground}" />
    </Style>

    <Style Selector="TextBlock.screenshot-counter.limit-reached">
        <Setter Property="Foreground" Value="{DynamicResource InterviewScreenshotCounterWarningForeground}" />
    </Style>

    <Style Selector="Button.btn-clear-screenshots">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="45" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource InterviewMicRecordingBackground}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.btn-clear-screenshots Viewbox">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>

    <Style Selector="Button.btn-clear-screenshots Path">
        <Setter Property="Fill" Value="{DynamicResource InterviewMicRecordingForeground}" />
        <Setter Property="Data" Value="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" />
    </Style>

</Styles>
