<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Controls.Shell.TitleBarDiagnosticsControl"
             x:TypeArguments="vm:TitleBarDiagnosticsViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
             xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels.Shell"
             xmlns:shellControls="clr-namespace:DarkBot.Net.Presentation.Controls.Shell"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             VerticalAlignment="Center"
             d:DataContext="{d:DesignInstance Type=vm:TitleBarDiagnosticsViewModel, IsDesignTimeCreatable=True}"
             d:DesignWidth="320"
             d:DesignHeight="32">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource TitleBarDiagnosticsBorder}"
            ToolTip="Tick · Память · Ping · FPS">
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">
            <shellControls:TitleBarDiagnosticMetricControl Caption="TICK"
                                                           Symbol="HeartPulse20"
                                                           Value="{Binding TickMsText}" />
            <shellControls:TitleBarDiagnosticMetricControl Caption="RAM"
                                                           Symbol="Memory16"
                                                           Value="{Binding MemoryMbText}" />
            <shellControls:TitleBarDiagnosticMetricControl Caption="PING"
                                                           Symbol="Wifi120"
                                                           Value="{Binding PingText}" />
            <shellControls:TitleBarDiagnosticMetricControl Caption="FPS"
                                                           Symbol="DesktopPulse16"
                                                           Value="{Binding FpsText}"
                                                           IsLast="True" />
        </StackPanel>
    </Border>
</rxui:ReactiveUserControl>
