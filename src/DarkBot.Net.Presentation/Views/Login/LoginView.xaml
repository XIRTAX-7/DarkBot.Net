<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Views.Login.LoginView"
        x:TypeArguments="vm:LoginViewModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
        xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        d:DesignWidth="520"
        d:DesignHeight="420">

  <Border Background="Transparent" Padding="24">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="1"
              Style="{DynamicResource DbPanel}"
              MaxWidth="520"
              HorizontalAlignment="Center">
        <StackPanel>
          <Border Style="{DynamicResource DbHero}" Margin="0,0,0,18">
            <StackPanel>
              <Border Style="{DynamicResource DbBadgeAccent}"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,6">
                <TextBlock Text="Unity client"
                           Foreground="{DynamicResource DbAccent}"
                           FontSize="11"
                           FontWeight="SemiBold" />
              </Border>
              <TextBlock Style="{DynamicResource DbTitle}" Text="DarkOrbit login" Margin="0,0,0,6" />
              <TextBlock Style="{DynamicResource DbSubtitle}"
                         Text="Введите логин и пароль. Авторизация выполняется в игре через TS-агент." />
            </StackPanel>
          </Border>

          <ui:TextBox Style="{DynamicResource DbInput}"
                      Margin="0,0,0,10"
                      PlaceholderText="Username"
                      Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                      IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

          <PasswordBox x:Name="PasswordBox"
                       Margin="0,0,0,10"
                       IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

          <CheckBox Content="Запомнить меня"
                    Margin="0,0,0,10"
                    IsChecked="{Binding RememberMe}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

          <Border Style="{DynamicResource DbCard}" Margin="0,0,0,18">
            <TextBlock Style="{DynamicResource DbSubtitle}"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
          </Border>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Style="{DynamicResource DbButtonGhost}"
                       Margin="0,0,10,0"
                       Content="Cancel"
                       IsCancel="True"
                       Click="OnCancelClick" />
            <ui:Button Style="{DynamicResource DbButtonPrimary}"
                       Content="Log in"
                       IsDefault="True"
                       Command="{Binding LoginCommand}"
                       IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</rxui:ReactiveUserControl>
