<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:DarkBot.Net.Ui.Controls"
        xmlns:vm="using:DarkBot.Net.Ui.ViewModels"
        x:Class="DarkBot.Net.Ui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="900" Height="600"
        MinWidth="640" MinHeight="480">
  <DockPanel>
    <Border DockPanel.Dock="Top" Background="#FF252A35" Padding="8">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
        <Button Grid.Column="0" Margin="0,0,8,0"
                Command="{Binding ToggleBotCommand}"
                Content="{Binding RunButtonText}" />
        <Button Grid.Column="1" Margin="0,0,8,0"
                Name="ConfigButton" Content="Config" />
        <Button Grid.Column="2" Margin="0,0,8,0"
                Name="LoginButton" Content="Login" />
        <TextBlock Grid.Column="3" VerticalAlignment="Center"
                   Text="{Binding StatusLine}" TextTrimming="CharacterEllipsis" />
        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" Margin="8,0">
          <TextBlock VerticalAlignment="Center" Text="Backpage:" Opacity="0.7" />
          <TextBlock VerticalAlignment="Center" Text="{Binding BackpageStatus}" />
        </StackPanel>
        <TextBlock Grid.Column="5" VerticalAlignment="Center" Opacity="0.6" Text="DarkBot.Net Phase 3" />
      </Grid>
    </Border>

    <Grid ColumnDefinitions="*,240">
      <controls:MapCanvasControl Grid.Column="0"
                                 Name="MapCanvas"
                                 Snapshot="{Binding Snapshot}" />
      <controls:StatsPanelControl Grid.Column="1"
                                  Name="StatsPanel" />
    </Grid>
  </DockPanel>
</Window>
