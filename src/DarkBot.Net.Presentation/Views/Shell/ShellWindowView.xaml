<views:ShellWindowViewBase x:Class="DarkBot.Net.Presentation.Views.Shell.ShellWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:DarkBot.Net.Presentation.Views.Shell"
        xmlns:loc="clr-namespace:DarkBot.Net.Presentation.Resources"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:shellControls="clr-namespace:DarkBot.Net.Presentation.Controls.Shell"
        mc:Ignorable="d"
        xml:lang="ru-RU"
        Title="{x:Static loc:UiStrings.App_Title}"
        Width="1100" Height="780"
        MinWidth="1100" MinHeight="780"
        ExtendsContentIntoTitleBar="True"
        Background="Transparent"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen"
        d:DesignWidth="1280"
        d:DesignHeight="820">

  <views:ShellWindowViewBase.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </views:ShellWindowViewBase.Resources>

  <Grid Background="Transparent">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0"
          Height="56"
          Margin="8,8,8,0">
      <Border Style="{StaticResource ShellTitleBarFrame}"
              IsHitTestVisible="False" />

      <ui:TitleBar Height="56"
                   Title="{Binding ApplicationTitle}"
                   Background="Transparent"
                   ButtonsBackground="Transparent"
                   ButtonsForeground="{DynamicResource TextFillColorPrimaryBrush}"
                   CloseWindowByDoubleClickOnIcon="True"
                   UseLayoutRounding="True">
        <ui:TitleBar.TrailingContent>
          <shellControls:TitleBarDiagnosticsControl DataContext="{Binding TitleBarDiagnostics}"
                                                     Margin="0,0,10,0" />
        </ui:TitleBar.TrailingContent>
      </ui:TitleBar>
    </Grid>

    <ContentControl Grid.Row="1"
                    x:Name="PageHost"
                    Background="Transparent"
                    Margin="0,0,0,8" />
  </Grid>
</views:ShellWindowViewBase>
