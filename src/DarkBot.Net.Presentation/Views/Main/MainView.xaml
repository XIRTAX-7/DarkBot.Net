<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Views.Main.MainView"
        x:TypeArguments="vm:MainWindowViewModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
        xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:DarkBot.Net.Presentation.Controls"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="820">

  <Border Background="Transparent">
    <Grid Margin="18">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Style="{DynamicResource DbToolbar}" Margin="0,0,0,14">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <ui:Button Grid.Column="0"
                     Style="{DynamicResource DbButtonPrimary}"
                     Margin="0,0,10,0"
                     Command="{Binding ToggleBotCommand}"
                     Content="{Binding RunButtonText}" />

          <ui:Button Grid.Column="1"
                     x:Name="ConfigButton"
                     Style="{DynamicResource DbButtonSecondary}"
                     Margin="0,0,10,0"
                     Content="Config" />

          <ui:Button Grid.Column="2"
                     x:Name="LoginButton"
                     Style="{DynamicResource DbButtonGhost}"
                     Margin="0,0,10,0"
                     Content="Login" />

          <ui:Button Grid.Column="3"
                     Style="{DynamicResource DbIconButton}"
                     Margin="0,0,10,0"
                     Command="{Binding RestartClientCommand}"
                     IsEnabled="{Binding CanRestartClient}"
                     ToolTip="Перезапуск клиента">
            <Viewbox Width="16" Height="16" Stretch="Uniform">
              <Path Data="{DynamicResource DbRefreshIconGeometry}"
                    Fill="{DynamicResource DbTextSecondary}" />
            </Viewbox>
          </ui:Button>

          <Border Grid.Column="4"
                  Style="{DynamicResource DbBadge}"
                  Margin="4,0"
                  Padding="12,6">
            <TextBlock Text="{Binding StatusLine}"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DbTextSecondary}"
                       FontSize="11"
                       FontWeight="SemiBold" />
          </Border>

          <TextBlock Grid.Column="5"
                     Style="{DynamicResource DbCaption}"
                     VerticalAlignment="Center"
                     Text="DarkBot.Net Phase 3" />
        </Grid>
      </Border>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{DynamicResource DbMapFrame}" Margin="0,0,14,0">
          <controls:MapCanvasControl x:Name="MapCanvas"
                                     Snapshot="{Binding Snapshot}" />
        </Border>

        <controls:StatsPanelControl Grid.Column="1"
                                    x:Name="StatsPanel" />
      </Grid>
    </Grid>
  </Border>
</rxui:ReactiveUserControl>
