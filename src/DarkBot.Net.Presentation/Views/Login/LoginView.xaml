<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Views.Login.LoginView"
        x:TypeArguments="vm:LoginViewModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
        xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels.Login"
        xmlns:loc="clr-namespace:DarkBot.Net.Presentation.Resources"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        xml:lang="ru-RU"
        d:DesignWidth="520"
        d:DesignHeight="420">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid Style="{StaticResource WpfUiViewHostGrid}" Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <ui:Card Grid.Row="1"
             MaxWidth="520"
             HorizontalAlignment="Center"
             Padding="24">
      <StackPanel>
        <StackPanel Margin="0,0,0,20">
          <ui:InfoBadge Value="{x:Static loc:UiStrings.Login_UnityClientBadge}"
                        Severity="Informational"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,8" />
          <ui:TextBlock FontTypography="TitleLarge"
                        Text="{x:Static loc:UiStrings.Login_Title}"
                        Margin="0,0,0,8" />
          <ui:TextBlock FontTypography="Body"
                        Appearance="Secondary"
                        TextWrapping="Wrap"
                        Text="{x:Static loc:UiStrings.Login_Description}" />
        </StackPanel>

        <ui:TextBox Margin="0,0,0,12"
                    PlaceholderText="{x:Static loc:UiStrings.Login_UsernamePlaceholder}"
                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

        <ui:PasswordBox Margin="0,0,0,12"
                        PlaceholderText="{x:Static loc:UiStrings.Login_PasswordPlaceholder}"
                        Icon="{ui:SymbolIcon Password24}"
                        Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

        <ui:ToggleSwitch Content="{x:Static loc:UiStrings.Login_RememberMe}"
                         LabelPosition="Left"
                         Margin="0,0,0,16"
                         IsChecked="{Binding RememberMe}"
                         IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

        <ui:InfoBar Title="{x:Static loc:UiStrings.Login_StatusTitle}"
                    Margin="0,0,0,20"
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Informational"
                    Message="{Binding StatusMessage}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <ui:Button Appearance="Transparent"
                     Margin="0,0,8,0"
                     Content="{x:Static loc:UiStrings.Login_Cancel}"
                     IsCancel="True"
                     Click="OnCancelClick" />
          <ui:Button Appearance="Primary"
                     Content="{x:Static loc:UiStrings.Login_Submit}"
                     IsDefault="True"
                     Command="{Binding LoginCommand}"
                     IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
        </StackPanel>
      </StackPanel>
    </ui:Card>
  </Grid>
</rxui:ReactiveUserControl>
