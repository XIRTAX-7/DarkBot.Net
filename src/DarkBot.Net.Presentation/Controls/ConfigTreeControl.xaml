<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Controls.ConfigTreeControl"
             x:TypeArguments="vm:ConfigTreeViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
             xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels"
             xmlns:pages="clr-namespace:DarkBot.Net.Presentation.Views.Config.Pages"
             xmlns:controls="clr-namespace:DarkBot.Net.Presentation.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignWidth="1180"
             d:DesignHeight="760">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid Style="{StaticResource WpfUiViewHostGrid}">
  <ui:TabView>
    <ui:TabViewItem IsSelected="True">
      <ui:TabViewItem.Header>
        <StackPanel Orientation="Horizontal">
          <ui:SymbolIcon Margin="0,0,8,0" Symbol="Settings24" />
          <ui:TextBlock FontTypography="Body" Text="Общие настройки" />
        </StackPanel>
      </ui:TabViewItem.Header>
      <ui:NavigationView x:Name="ConfigNavigation"
                         PaneDisplayMode="Left"
                         IsBackButtonVisible="Collapsed"
                         IsPaneToggleVisible="False"
                         IsTopSeparatorVisible="False"
                         FrameMargin="0"
                         OpenPaneLength="240"
                         Transition="FadeInWithSlide">
        <ui:NavigationView.MenuItems>
          <ui:NavigationViewItem Content="Главная"
                                 NavigationCacheMode="Enabled"
                                 TargetPageType="{x:Type pages:ConfigMainPage}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="Home24" />
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="Сбор"
                                 NavigationCacheMode="Enabled"
                                 TargetPageType="{x:Type pages:ConfigCollectPage}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="Box24" />
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="Убийство NPC"
                                 Tag="{x:Static vm:ConfigSidebarSection.NpcKill}"
                                 TargetPageType="{x:Type pages:ConfigPlaceholderPage}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="Target24" />
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="PET"
                                 Tag="{x:Static vm:ConfigSidebarSection.Pet}"
                                 TargetPageType="{x:Type pages:ConfigPlaceholderPage}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="AnimalCat24" />
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="Группа"
                                 Tag="{x:Static vm:ConfigSidebarSection.Group}"
                                 TargetPageType="{x:Type pages:ConfigPlaceholderPage}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="PeopleTeam24" />
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="Прочее"
                                 Tag="{x:Static vm:ConfigSidebarSection.Other}"
                                 TargetPageType="{x:Type pages:ConfigPlaceholderPage}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="MoreHorizontal24" />
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
        </ui:NavigationView.MenuItems>
        <ui:NavigationView.FooterMenuItems>
          <ui:NavigationViewItem Content="Настройки бота"
                                 Tag="{x:Static vm:ConfigSidebarSection.BotSettings}"
                                 TargetPageType="{x:Type pages:ConfigPlaceholderPage}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="Settings24" />
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="Plugins"
                                 Tag="{x:Static vm:ConfigSidebarSection.Plugins}"
                                 TargetPageType="{x:Type pages:ConfigPlaceholderPage}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="PlugConnected24" />
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
        </ui:NavigationView.FooterMenuItems>
        <ui:NavigationView.PaneFooter>
          <!-- PaneFooter рендерится через ContentPresenter в шаблоне NavigationView и теряет DataContext -->
          <ComboBox x:Name="VisibilityLevelCombo"
                    Margin="4,12,4,4"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding ViewModel.VisibilityLevels, RelativeSource={RelativeSource AncestorType=controls:ConfigTreeControl}}"
                    SelectedItem="{Binding ViewModel.SelectedVisibilityLevel, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=controls:ConfigTreeControl}}"
                    DisplayMemberPath="Title" />
        </ui:NavigationView.PaneFooter>
      </ui:NavigationView>
    </ui:TabViewItem>

    <ui:TabViewItem>
      <ui:TabViewItem.Header>
        <StackPanel Orientation="Horizontal">
          <ui:SymbolIcon Margin="0,0,8,0" Symbol="Map24" />
          <ui:TextBlock FontTypography="Body" Text="Зоны карты" />
        </StackPanel>
      </ui:TabViewItem.Header>
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:Card Grid.Row="0" Margin="0,0,0,16" Padding="16">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <ui:TextBlock FontTypography="Subtitle" Text="Зоны карты" Margin="0,0,0,4" />
              <ui:TextBlock FontTypography="Caption"
                            Appearance="Secondary"
                            Text="Редактор разметки 30 x 30 для предпочтительных, запретных и безопасных зон." />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
              <ui:Button Appearance="Secondary" Content="Очистить" Margin="0,0,8,0" />
              <ui:Button Appearance="Primary" Content="Применить" />
            </StackPanel>
          </Grid>
        </ui:Card>

        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
          </Grid.ColumnDefinitions>

          <ui:Card Grid.Column="0" Margin="0,0,16,0" Padding="0">
            <Border ClipToBounds="True"
                    CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1">
              <Border MinHeight="470"
                      Background="{DynamicResource ControlFillColorSecondaryBrush}">
                <Grid>
                  <Border Grid.Row="4" Grid.Column="6"
                          Margin="1"
                          CornerRadius="2"
                          BorderThickness="1"
                          Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                          BorderBrush="{DynamicResource SystemFillColorSuccessBrush}" />
                  <Border Grid.Row="10" Grid.Column="14"
                          Margin="1"
                          CornerRadius="2"
                          BorderThickness="1"
                          Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                          BorderBrush="{DynamicResource SystemFillColorCriticalBrush}" />
                  <Border Grid.Row="20" Grid.Column="5"
                          Margin="1"
                          CornerRadius="2"
                          BorderThickness="1"
                          Background="{DynamicResource AccentFillColorSecondaryBrush}"
                          BorderBrush="{DynamicResource AccentFillColorDefaultBrush}" />
                  <Ellipse Grid.Row="14" Grid.Column="15"
                           Width="10" Height="10"
                           Fill="{DynamicResource TextFillColorPrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Border>
          </ui:Card>

          <ui:CardControl Grid.Column="1"
                          Icon="{ui:SymbolIcon PaintBrush24}">
            <ui:CardControl.Header>
              <StackPanel>
                <ui:TextBlock FontTypography="Body" Text="Режим выделения" />
                <ui:TextBlock FontTypography="Caption"
                              Appearance="Secondary"
                              Text="Кисть добавляет квадраты, ластик удаляет"
                              TextWrapping="Wrap" />
              </StackPanel>
            </ui:CardControl.Header>
            <ComboBox MinWidth="200" SelectedIndex="0">
              <ComboBoxItem Content="Кисть: добавить квадраты" />
              <ComboBoxItem Content="Ластик: удалить квадраты" />
            </ComboBox>
          </ui:CardControl>
        </Grid>
      </Grid>
    </ui:TabViewItem>
  </ui:TabView>
  </Grid>
</rxui:ReactiveUserControl>
