<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════════════
         Sidebar Navigation — панель, пункты меню, действия
         Цвета: App.axaml → ThemeDictionaries (MainSidebar*)
         ══════════════════════════════════════════════════════════════ -->

    <!-- ─── Панель: ширина + fade и состояние развёрнут/свёрнут ─── -->
    <Style Selector="Border#SidebarPanel">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Width"
                                  Duration="0:0:0.22" />
                <DoubleTransition Property="Opacity"
                                  Duration="0:0:0.14" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border#SidebarPanel:not(.collapsed)">
        <Setter Property="Width" Value="260" />
    </Style>

    <Style Selector="Border#SidebarPanel.collapsed">
        <Setter Property="Width" Value="68" />
    </Style>

    <!-- ─── Общая база кнопок сайдбара (sidebarButton + sidebarAction | navItem) ─── -->
    <Style Selector="Button.sidebarButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button.sidebarButton /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Button.sidebarButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource MainSidebarItemHover}" />
    </Style>

    <!-- Кнопки «Свернуть» / «Сменить тему» -->
    <Style Selector="Button.sidebarAction">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Button.sidebarActionCollapsed">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Button.sidebarAction Path">
        <Setter Property="Fill" Value="{DynamicResource MainSidebarIconForeground}" />
    </Style>

    <Style Selector="Button.sidebarAction:pointerover Path">
        <Setter Property="Fill" Value="{DynamicResource MainSidebarIconActiveForeground}" />
    </Style>

    <!-- Пункты навигации -->
    <Style Selector="Button.navItem">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style Selector="Button.navItem.collapsed">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="0,10" />
    </Style>

    <Style Selector="Button.navItem.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource MainSidebarItemActive}" />
    </Style>

    <Style Selector="Button.navItem Path">
        <Setter Property="Fill" Value="{DynamicResource MainSidebarIconForeground}" />
    </Style>

    <Style Selector="Button.navItem TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MainSidebarLabelForeground}" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style Selector="Button.navItem.active Path">
        <Setter Property="Fill" Value="{DynamicResource MainSidebarIconActiveForeground}" />
    </Style>

    <Style Selector="Button.navItem.active TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MainSidebarIconActiveForeground}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- ─── Декоративные элементы ─── -->
    <Style Selector="Border.sidebarDivider">
        <Setter Property="Height" Value="1" />
        <Setter Property="Opacity" Value="0.3" />
        <Setter Property="Background" Value="{DynamicResource MainSidebarBorder}" />
    </Style>

    <Style Selector="Border.sidebarLogo">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="BoxShadow" Value="0 4 16 -2 #307C5CFC" />
    </Style>

    <Style Selector="Border.sidebarProfile">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="Background" Value="{DynamicResource MainSidebarItemHover}" />
    </Style>

    <Style Selector="Border.sidebarBalance">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="Background" Value="{DynamicResource MainSidebarItemHover}" />
    </Style>

    <Style Selector="Border.sidebarAvatarCollapsed">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="CornerRadius" Value="18" />
    </Style>

    <Style Selector="Border.sidebarAccentGradient">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="{DynamicResource AccentGradientStart}" Offset="0" />
                <GradientStop Color="{DynamicResource AccentGradientEnd}" Offset="1" />
            </LinearGradientBrush>
        </Setter>
    </Style>

    <Style Selector="Border.sidebarUserBadge.size34">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="CornerRadius" Value="17" />
    </Style>

    <Style Selector="TextBlock.sidebarUserInitial">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</Styles>
