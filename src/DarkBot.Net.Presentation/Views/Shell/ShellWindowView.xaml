<rxui:ReactiveWindow x:Class="DarkBot.Net.Presentation.Views.Shell.ShellWindowView"
        x:TypeArguments="vm:ShellWindowViewModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
        xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels.Shell"
        mc:Ignorable="d"
        Title="DarkBot.Net"
        Width="1280" Height="820"
        MinWidth="1100" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        d:DesignWidth="1280"
        d:DesignHeight="820">

  <Grid>
    <Border ClipToBounds="True"
            Background="{DynamicResource DbShellBackgroundImage}" />

    <Border Background="#660A0D16" />

    <ContentControl x:Name="PageHost" />
  </Grid>
</rxui:ReactiveWindow>
