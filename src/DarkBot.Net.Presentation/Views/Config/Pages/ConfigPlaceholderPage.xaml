<Page x:Class="DarkBot.Net.Presentation.Views.Config.Pages.ConfigPlaceholderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:DarkBot.Net.Presentation.Resources"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="{x:Static loc:UiStrings.ConfigPlaceholder_PageTitle}"
      xml:lang="ru-RU">

  <Page.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Page.Resources>

  <Grid Style="{StaticResource WpfUiViewHostGrid}">
    <ui:Card Margin="0,0,8,0" Padding="24">
      <ui:TextBlock FontTypography="Body"
                    Appearance="Secondary"
                    Text="{Binding PlaceholderMessage}"
                    TextWrapping="Wrap" />
    </ui:Card>
  </Grid>
</Page>
