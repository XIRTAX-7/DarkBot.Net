<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Views.Main.MainView"
        x:TypeArguments="vm:MainWindowViewModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
        xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels.Main"
        xmlns:loc="clr-namespace:DarkBot.Net.Presentation.Resources"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:mainControls="clr-namespace:DarkBot.Net.Presentation.Controls.Main"
        xmlns:mapCanvas="clr-namespace:DarkBot.Net.Presentation.Controls.Main.MapCanvas"
        mc:Ignorable="d"
        xml:lang="ru-RU"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=True}"
        d:DesignWidth="1280"
        d:DesignHeight="820">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Style="{StaticResource WpfUiViewHostGrid}" Margin="20,12,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="395" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:Card Grid.Row="0" Margin="0" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Margin="0,0,14,0">
                        <Border Style="{StaticResource MainBrandMarkBorder}" Margin="0,0,10,0">
                            <ui:SymbolIcon Symbol="Shield24"
                             FontSize="18"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                        </Border>
                        <ui:TextBlock FontTypography="Subtitle"
                          VerticalAlignment="Center"
                          Text="{x:Static loc:UiStrings.App_Title}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                  Style="{StaticResource MainStatusPillBorder}"
                  Margin="0,0,10,0"
                  MinWidth="220">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Ellipse Grid.Column="0"
                       Style="{StaticResource MainStatusDot}"
                       Margin="0,0,8,0" />
                            <ui:TextBlock Grid.Column="1"
                            FontTypography="Body"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="{Binding StatusLine, FallbackValue={x:Static loc:UiStrings.Main_Ready}, TargetNullValue={x:Static loc:UiStrings.Main_Ready}}"
                            TextTrimming="CharacterEllipsis"
                            VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                  Style="{StaticResource MainStatusPillBorder}"
                  Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:TextBlock Style="{StaticResource MainMetricCaption}"
                            Text="{x:Static loc:UiStrings.Main_ConfigLabel}"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0" />
                            <ComboBox Style="{StaticResource MainToolbarComboBox}"
                        SelectedIndex="0"
                        ToolTip="{x:Static loc:UiStrings.Main_ConfigSlotTooltip}">
                                <ComboBoxItem Content="{x:Static loc:UiStrings.Main_ConfigSlot1}" />
                                <ComboBoxItem Content="{x:Static loc:UiStrings.Main_ConfigSlot2}" />
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ui:Button x:Name="RestartClientButton"
                                   Style="{StaticResource MainCommandButton}"
                                   Appearance="Transparent"
                                   Content="{x:Static loc:UiStrings.Main_ClientButton}"
                                   ToolTip="{x:Static loc:UiStrings.Main_RestartClientTooltip}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="ArrowClockwise24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <mainControls:BotRunToggleButton x:Name="ToggleBotButton" />
                        <ui:Button x:Name="OpenConfigButton"
                                   Style="{StaticResource MainCommandButton}"
                                   Appearance="Secondary"
                                   Content="{x:Static loc:UiStrings.Main_ConfigButton}" />
                        <ui:Button x:Name="OpenLoginButton"
                                   Style="{StaticResource MainCommandButtonLast}"
                                   Appearance="Danger"
                                   Content="{x:Static loc:UiStrings.Main_LoginButton}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="SignOut24" Filled="True" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                </Grid>
        </ui:Card>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Style="{StaticResource WpfUiControlSurfaceBorder}"
                MinHeight="395">
            <mapCanvas:MapCanvasControl x:Name="MapCanvas"
                                        VerticalAlignment="Stretch"
                                        HorizontalAlignment="Stretch"
                                        Snapshot="{Binding Snapshot}" />
        </Border>

        <ui:Card Grid.Row="2" Padding="16,14">
            <StackPanel>
                <Grid MinHeight="120">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="240" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" MinWidth="220" MaxWidth="300" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" MinWidth="220" MaxWidth="300" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Grid Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="Shield24" FontSize="16" Margin="0,0,8,0" />
                                <ui:TextBlock Style="{StaticResource MainDashboardSectionTitle}"
                                              Text="{x:Static loc:UiStrings.Main_ShipSection}" />
                            </StackPanel>
                            <ui:TextBlock HorizontalAlignment="Right"
                                          Style="{StaticResource MainDashboardMetricLabel}"
                                          Text="{Binding Snapshot.Map.Hero.Configuration}"
                                          TextTrimming="CharacterEllipsis" />
                        </Grid>

                        <mainControls:HealthMetricRow Label="{x:Static loc:UiStrings.Main_Hp}"
                                                      Value="{Binding Snapshot.Map.Hero.Hp}"
                                                      Maximum="{Binding Snapshot.Map.Hero.MaxHp}"
                                                      OverflowValue="{Binding Snapshot.Map.Hero.Nano}"
                                                      OverflowMaximum="{Binding Snapshot.Map.Hero.MaxNano}"
                                                      FillBrush="{StaticResource MainDashboardHealthBrush}" />
                        <mainControls:HealthMetricRow Label="{x:Static loc:UiStrings.Main_Shield}"
                                                      Value="{Binding Snapshot.Map.Hero.Shield}"
                                                      Maximum="{Binding Snapshot.Map.Hero.MaxShield}"
                                                      FillBrush="{StaticResource MainDashboardShieldBrush}"
                                                      Margin="0,0,0,6" />

                        <StackPanel Orientation="Horizontal">
                            <ui:TextBlock Style="{StaticResource MainDashboardMetricLabel}"
                                          Text="{x:Static loc:UiStrings.Main_Position}" />
                            <ui:TextBlock Style="{StaticResource MainDashboardMetricValue}"
                                          Margin="8,0,0,0"
                                          Text="{Binding Snapshot.Map.Hero.X, StringFormat=N0}" />
                            <ui:TextBlock Style="{StaticResource MainDashboardMetricDivider}" Text="," />
                            <ui:TextBlock Style="{StaticResource MainDashboardMetricValue}"
                                          Text="{Binding Snapshot.Map.Hero.Y, StringFormat=N0}" />
                        </StackPanel>
                    </StackPanel>

                    <Rectangle Grid.Column="1"
                               x:Name="PetSectionSeparator"
                               Style="{StaticResource MainDashboardColumnSeparator}"
                               Visibility="{Binding IsPetSectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <StackPanel Grid.Column="2"
                                x:Name="PetSection"
                                Visibility="{Binding IsPetSectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:SymbolIcon Symbol="AnimalCat24" FontSize="16" Margin="0,0,8,0" />
                            <ui:TextBlock Style="{StaticResource MainDashboardSectionTitle}"
                                          Text="{x:Static loc:UiStrings.Main_PetSection}" />
                        </StackPanel>

                        <mainControls:HealthMetricRow Label="{x:Static loc:UiStrings.Main_Hp}"
                                                      Value="{Binding Snapshot.Map.Pet.Hp, TargetNullValue=0}"
                                                      Maximum="{Binding Snapshot.Map.Pet.MaxHp, TargetNullValue=0}"
                                                      FillBrush="{StaticResource MainDashboardHealthBrush}" />
                        <mainControls:HealthMetricRow Label="{x:Static loc:UiStrings.Main_Fuel}"
                                                      Value="{Binding Snapshot.Map.Pet.Fuel, TargetNullValue=0}"
                                                      Maximum="{Binding Snapshot.Map.Pet.MaxFuel, TargetNullValue=0}"
                                                      FillBrush="{StaticResource MainDashboardFuelBrush}"
                                                      Margin="0" />
                    </StackPanel>

                    <Rectangle Grid.Column="3"
                               x:Name="GroupSectionSeparator"
                               Style="{StaticResource MainDashboardColumnSeparator}"
                               Visibility="{Binding IsGroupSectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <StackPanel Grid.Column="4"
                                x:Name="GroupSection"
                                Visibility="{Binding IsGroupSectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:SymbolIcon Symbol="PeopleTeam24" FontSize="16" Margin="0,0,8,0" />
                            <ui:TextBlock Style="{StaticResource MainDashboardSectionTitle}"
                                          Text="{x:Static loc:UiStrings.Main_GroupSection}" />
                            <ui:TextBlock Style="{StaticResource MainDashboardMetricValueMuted}"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center">
                                <Run Text="{Binding Snapshot.Map.Overlay.GroupMembers.Count, Mode=OneWay}" />
                                <Run Text="{x:Static loc:UiStrings.Main_GroupMembersCountUnit}" />
                            </ui:TextBlock>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Snapshot.Map.Overlay.GroupMembers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,8">
                                        <Grid Margin="0,0,0,4">
                                            <ui:TextBlock Text="{Binding DisplayText}"
                                                          Style="{StaticResource MainDashboardMetricLabel}"
                                                          TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <ui:TextBlock Style="{StaticResource MainDashboardMetricValue}"
                                                              Text="{Binding Hp, StringFormat=N0}" />
                                                <ui:TextBlock Style="{StaticResource MainDashboardMetricDivider}" Text="/" />
                                                <ui:TextBlock Style="{StaticResource MainDashboardMetricValueMuted}"
                                                              Text="{Binding MaxHp, StringFormat=N0}" />
                                            </StackPanel>
                                        </Grid>
                                        <ProgressBar Style="{StaticResource MainDashboardHealthProgressBar}"
                                                     Value="{Binding Hp}"
                                                     Maximum="{Binding MaxHp}"
                                                     Foreground="{StaticResource MainDashboardGroupBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <Separator Style="{StaticResource WpfUiDivider}" Margin="0,14,0,14" />

                <mainControls:StatsPanelControl x:Name="StatsPanel" />
            </StackPanel>
        </ui:Card>
    </Grid>
</rxui:ReactiveUserControl>
