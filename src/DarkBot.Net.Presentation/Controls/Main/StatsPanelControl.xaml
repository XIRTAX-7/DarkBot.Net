<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Controls.Main.StatsPanelControl"
             x:TypeArguments="vm:StatsPanelViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
             xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels.Main"
             xmlns:loc="clr-namespace:DarkBot.Net.Presentation.Resources"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:StatsPanelViewModel, IsDesignTimeCreatable=True}"
             d:DesignWidth="1060"
             d:DesignHeight="36">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <DockPanel LastChildFill="True" VerticalAlignment="Center">
    <StackPanel DockPanel.Dock="Right"
                Orientation="Horizontal"
                VerticalAlignment="Center">
      <Rectangle Style="{StaticResource MainStatsInlineSeparator}" />
      <ui:TextBlock Style="{StaticResource MainStatsInlineCaption}"
                    Text="{x:Static loc:UiStrings.Main_Stats_Cargo}"
                    VerticalAlignment="Center" />
      <ui:TextBlock Style="{StaticResource MainStatsInlineValue}"
                    Text="{Binding Cargo, StringFormat=N0}"
                    VerticalAlignment="Center" />
      <ui:TextBlock Style="{StaticResource MainStatsInlineDivider}"
                    Text="/"
                    VerticalAlignment="Center" />
      <ui:TextBlock Style="{StaticResource MainStatsInlineValueMuted}"
                    Text="{Binding MaxCargo, StringFormat=N0}"
                    VerticalAlignment="Center" />
    </StackPanel>

    <StackPanel DockPanel.Dock="Left"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                ToolTip="{Binding SessionStateText}">
      <ui:SymbolIcon Symbol="Timer24"
                     FontSize="16"
                     Margin="0,0,8,0"
                     VerticalAlignment="Center" />
      <ui:TextBlock Style="{StaticResource MainStatsRunningTime}"
                    Text="{Binding RunningTimeText}"
                    VerticalAlignment="Center" />
      <Rectangle Style="{StaticResource MainStatsInlineSeparator}" />
    </StackPanel>

    <UniformGrid Columns="4" VerticalAlignment="Center">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <ui:TextBlock Style="{StaticResource MainStatsInlineCaption}"
                      Text="{x:Static loc:UiStrings.Main_Stats_CreditsPerHour}"
                      VerticalAlignment="Center" />
        <ui:TextBlock Style="{StaticResource MainStatsInlineValue}"
                      Margin="6,0,0,0"
                      Text="{Binding EarnedCreditsPerHour, StringFormat=N0}"
                      VerticalAlignment="Center" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <ui:TextBlock Style="{StaticResource MainStatsInlineCaption}"
                      Text="{x:Static loc:UiStrings.Main_Stats_UridiumPerHour}"
                      VerticalAlignment="Center" />
        <ui:TextBlock Style="{StaticResource MainStatsInlineValue}"
                      Margin="6,0,0,0"
                      Text="{Binding EarnedUridiumPerHour, StringFormat=N0}"
                      VerticalAlignment="Center" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <ui:TextBlock Style="{StaticResource MainStatsInlineCaption}"
                      Text="{x:Static loc:UiStrings.Main_Stats_ExperiencePerHour}"
                      VerticalAlignment="Center" />
        <ui:TextBlock Style="{StaticResource MainStatsInlineValue}"
                      Margin="6,0,0,0"
                      Text="{Binding EarnedExperiencePerHour, StringFormat=N0}"
                      VerticalAlignment="Center" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <ui:TextBlock Style="{StaticResource MainStatsInlineCaption}"
                      Text="{x:Static loc:UiStrings.Main_Stats_HonorPerHour}"
                      VerticalAlignment="Center" />
        <ui:TextBlock Style="{StaticResource MainStatsInlineValue}"
                      Margin="6,0,0,0"
                      Text="{Binding EarnedHonorPerHour, StringFormat=N0}"
                      VerticalAlignment="Center" />
      </StackPanel>
    </UniformGrid>
  </DockPanel>
</rxui:ReactiveUserControl>
