<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Controls.StatsPanelControl"
             x:TypeArguments="vm:StatsPanelViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
             xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignWidth="240"
             d:DesignHeight="480">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid Style="{StaticResource WpfUiViewHostGrid}">
  <ui:Card Padding="16">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <StackPanel Margin="0,0,0,16">
          <ui:TextBlock FontTypography="Subtitle" Text="Ship telemetry" Margin="0,0,0,4" />
          <ui:TextBlock FontTypography="Caption"
                        Appearance="Secondary"
                        Text="Economy, runtime and network metrics." />
        </StackPanel>

        <Grid Margin="0,0,0,16">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <ui:Card Grid.Row="0" Grid.Column="0" Margin="0,0,4,8" Padding="12">
            <StackPanel>
              <ui:TextBlock FontTypography="Caption" Appearance="Secondary" Text="Credits" Margin="0,0,0,4" />
              <ui:TextBlock FontTypography="Title" Text="{Binding Credits, StringFormat=N0}" />
            </StackPanel>
          </ui:Card>

          <ui:Card Grid.Row="0" Grid.Column="1" Margin="4,0,0,8" Padding="12">
            <StackPanel>
              <ui:TextBlock FontTypography="Caption" Appearance="Secondary" Text="Uridium" Margin="0,0,0,4" />
              <ui:TextBlock FontTypography="Title" Text="{Binding Uridium, StringFormat=N0}" />
            </StackPanel>
          </ui:Card>

          <ui:Card Grid.Row="1" Grid.Column="0" Margin="0,0,4,0" Padding="12">
            <StackPanel>
              <ui:TextBlock FontTypography="Caption" Appearance="Secondary" Text="Experience" Margin="0,0,0,4" />
              <ui:TextBlock FontTypography="Title" Text="{Binding Experience, StringFormat=N0}" />
            </StackPanel>
          </ui:Card>

          <ui:Card Grid.Row="1" Grid.Column="1" Margin="4,0,0,0" Padding="12">
            <StackPanel>
              <ui:TextBlock FontTypography="Caption" Appearance="Secondary" Text="Honor" Margin="0,0,0,4" />
              <ui:TextBlock FontTypography="Title" Text="{Binding Honor, StringFormat=N0}" />
            </StackPanel>
          </ui:Card>
        </Grid>

        <Separator Margin="0,0,0,16" Style="{StaticResource WpfUiDivider}" />

        <StackPanel Margin="0,0,0,16">
          <ui:Card Margin="0,0,0,8" Padding="12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <ui:TextBlock FontTypography="Caption" Appearance="Secondary" Text="Ping" Margin="0,0,0,2" />
                <ui:TextBlock FontTypography="Body" Appearance="Secondary" Text="Current connection latency" />
              </StackPanel>
              <ui:TextBlock Grid.Column="1"
                            FontTypography="Subtitle"
                            FontFamily="Cascadia Mono, Consolas, monospace"
                            Text="{Binding Ping, StringFormat={}{0} ms}" />
            </Grid>
          </ui:Card>

          <ui:Card Margin="0,0,0,8" Padding="12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <ui:TextBlock FontTypography="Caption" Appearance="Secondary" Text="Ticks" Margin="0,0,0,2" />
                <ui:TextBlock FontTypography="Body" Appearance="Secondary" Text="Bot loop updates" />
              </StackPanel>
              <ui:TextBlock Grid.Column="1"
                            FontTypography="Subtitle"
                            FontFamily="Cascadia Mono, Consolas, monospace"
                            Text="{Binding TickCount}" />
            </Grid>
          </ui:Card>

          <ui:Card Padding="12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <ui:TextBlock FontTypography="Caption" Appearance="Secondary" Text="Last tick" Margin="0,0,0,2" />
                <ui:TextBlock FontTypography="Body" Appearance="Secondary" Text="Processing duration" />
              </StackPanel>
              <ui:TextBlock Grid.Column="1"
                            FontTypography="Subtitle"
                            FontFamily="Cascadia Mono, Consolas, monospace"
                            Text="{Binding LastTickMs, StringFormat={}{0:0.#} ms}" />
            </Grid>
          </ui:Card>
        </StackPanel>

        <ui:Card Padding="12,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Style="{StaticResource WpfUiAccentCaption}" Text="Runtime" />
            <ui:TextBlock Grid.Column="1"
                          Style="{StaticResource WpfUiAccentMonospaceCaption}"
                          Text="{Binding Runtime}" />
          </Grid>
        </ui:Card>
      </StackPanel>
    </ScrollViewer>
  </ui:Card>
  </Grid>
</rxui:ReactiveUserControl>
