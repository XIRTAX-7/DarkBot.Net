# Local archive (DarkMem native — not used in Frida-only v1)
archive/

# Build output
**/bin/
**/obj/
**/TestResults/
**/build/
!**/build-bridge.ps1
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/

# Java / Python artifacts
**/__pycache__/
*.pyc
*.class

# Logs and local runtime
logs/
**/logs/
*.log
*.log.err

# Native libraries (downloaded at runtime via NativeLibrarySetup)
/lib/*
!/lib/.gitkeep
**/lib/*.dll
**/lib/*.jar

# NuGet
*.nupkg
project.lock.json

# OS
Thumbs.db
.DS_Store

# IDE
.idea/
*.swp
*.DotSettings.user

# Legacy Electron-клиент (не коммитить)
Darkorbit-client-old/

# Secrets
*.env
.env.*
appsettings.Development.json
appsettings.Local.json

# Coverage
coverage/
*.coverage
