<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Controls.Shell.TitleBarDiagnosticsControl"
             x:TypeArguments="vm:TitleBarDiagnosticsViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
             xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels.Shell"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignWidth="360"
             d:DesignHeight="36">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource TitleBarDiagnosticsBorder}"
            ToolTip="Tick · Память · Ping · FPS">
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">
            <Border Style="{StaticResource TitleBarDiagnosticMetricPill}">
                <StackPanel Style="{StaticResource TitleBarDiagnosticMetricPanel}">
                    <Border Style="{StaticResource TitleBarDiagnosticIconSurface}">
                        <ui:SymbolIcon Symbol="HeartPulse24"
                                       Style="{StaticResource TitleBarDiagnosticIcon}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <ui:TextBlock Style="{StaticResource TitleBarDiagnosticCaption}"
                                      Text="TICK" />
                        <ui:TextBlock Style="{StaticResource TitleBarDiagnosticValue}"
                                      Text="{Binding TickMsText}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource TitleBarDiagnosticMetricPill}">
                <StackPanel Style="{StaticResource TitleBarDiagnosticMetricPanel}">
                    <Border Style="{StaticResource TitleBarDiagnosticIconSurface}">
                        <ui:SymbolIcon Symbol="Memory16"
                                       Style="{StaticResource TitleBarDiagnosticIcon}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <ui:TextBlock Style="{StaticResource TitleBarDiagnosticCaption}"
                                      Text="RAM" />
                        <ui:TextBlock Style="{StaticResource TitleBarDiagnosticValue}"
                                      Text="{Binding MemoryMbText}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource TitleBarDiagnosticMetricPill}">
                <StackPanel Style="{StaticResource TitleBarDiagnosticMetricPanel}">
                    <Border Style="{StaticResource TitleBarDiagnosticIconSurface}">
                        <ui:SymbolIcon Symbol="Wifi124"
                                       Style="{StaticResource TitleBarDiagnosticIcon}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <ui:TextBlock Style="{StaticResource TitleBarDiagnosticCaption}"
                                      Text="PING" />
                        <ui:TextBlock Style="{StaticResource TitleBarDiagnosticValue}"
                                      Text="{Binding PingText}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource TitleBarDiagnosticMetricPillLast}">
                <StackPanel Style="{StaticResource TitleBarDiagnosticMetricPanel}">
                    <Border Style="{StaticResource TitleBarDiagnosticIconSurface}">
                        <ui:SymbolIcon Symbol="DesktopPulse24"
                                       Style="{StaticResource TitleBarDiagnosticIcon}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <ui:TextBlock Style="{StaticResource TitleBarDiagnosticCaption}"
                                      Text="FPS" />
                        <ui:TextBlock Style="{StaticResource TitleBarDiagnosticValue}"
                                      Text="{Binding FpsText}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</rxui:ReactiveUserControl>
