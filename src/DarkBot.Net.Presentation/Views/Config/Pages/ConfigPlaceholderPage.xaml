<Page x:Class="DarkBot.Net.Presentation.Views.Config.Pages.ConfigPlaceholderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:DarkBot.Net.Presentation.Resources"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="{x:Static loc:UiStrings.ConfigPlaceholder_PageTitle}"
      xml:lang="ru-RU"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Background="{DynamicResource ApplicationBackgroundBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

  <ui:Card Margin="0,0,8,0" Padding="24">
    <ui:TextBlock FontTypography="Body"
                  Appearance="Secondary"
                  Text="{Binding PlaceholderMessage}"
                  TextWrapping="Wrap" />
  </ui:Card>
</Page>
