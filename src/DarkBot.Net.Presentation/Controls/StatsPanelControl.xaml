<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Controls.StatsPanelControl"
             x:TypeArguments="vm:StatsPanelViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
             xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="240"
             d:DesignHeight="480">

  <Border Style="{DynamicResource DbPanelSoft}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <StackPanel Margin="0,0,0,14">
          <TextBlock Style="{DynamicResource DbSectionTitle}" Text="Ship telemetry" Margin="0,0,0,3" />
          <TextBlock Style="{DynamicResource DbCaption}" Text="Economy, runtime and network metrics." />
        </StackPanel>

        <Grid Margin="0,0,0,14">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border Grid.Row="0" Grid.Column="0" Style="{DynamicResource DbMetricTile}" Margin="0,0,5,10">
            <StackPanel>
              <TextBlock Style="{DynamicResource DbMetricLabel}" Text="Credits" Margin="0,0,0,4" />
              <TextBlock Style="{DynamicResource DbMetricValue}"
                         Text="{Binding Credits, StringFormat=N0}" />
            </StackPanel>
          </Border>

          <Border Grid.Row="0" Grid.Column="1" Style="{DynamicResource DbMetricTile}" Margin="5,0,0,10">
            <StackPanel>
              <TextBlock Style="{DynamicResource DbMetricLabel}" Text="Uridium" Margin="0,0,0,4" />
              <TextBlock Style="{DynamicResource DbMetricValue}"
                         Text="{Binding Uridium, StringFormat=N0}" />
            </StackPanel>
          </Border>

          <Border Grid.Row="1" Grid.Column="0" Style="{DynamicResource DbMetricTile}" Margin="0,0,5,0">
            <StackPanel>
              <TextBlock Style="{DynamicResource DbMetricLabel}" Text="Experience" Margin="0,0,0,4" />
              <TextBlock Style="{DynamicResource DbMetricValue}"
                         Text="{Binding Experience, StringFormat=N0}" />
            </StackPanel>
          </Border>

          <Border Grid.Row="1" Grid.Column="1" Style="{DynamicResource DbMetricTile}" Margin="5,0,0,0">
            <StackPanel>
              <TextBlock Style="{DynamicResource DbMetricLabel}" Text="Honor" Margin="0,0,0,4" />
              <TextBlock Style="{DynamicResource DbMetricValue}"
                         Text="{Binding Honor, StringFormat=N0}" />
            </StackPanel>
          </Border>
        </Grid>

        <Border Style="{DynamicResource DbDivider}" Margin="0,0,0,14" />

        <StackPanel Margin="0,0,0,14">
          <Border Style="{DynamicResource DbCard}" Margin="0,0,0,10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Style="{DynamicResource DbMetricLabel}" Text="Ping" Margin="0,0,0,2" />
                <TextBlock Style="{DynamicResource DbSubtitle}" Text="Current connection latency" />
              </StackPanel>
              <TextBlock Grid.Column="1"
                         Style="{DynamicResource DbSectionTitle}"
                         FontFamily="Cascadia Mono, Consolas, monospace"
                         Text="{Binding Ping, StringFormat={}{0} ms}" />
            </Grid>
          </Border>

          <Border Style="{DynamicResource DbCard}" Margin="0,0,0,10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Style="{DynamicResource DbMetricLabel}" Text="Ticks" Margin="0,0,0,2" />
                <TextBlock Style="{DynamicResource DbSubtitle}" Text="Bot loop updates" />
              </StackPanel>
              <TextBlock Grid.Column="1"
                         Style="{DynamicResource DbSectionTitle}"
                         FontFamily="Cascadia Mono, Consolas, monospace"
                         Text="{Binding TickCount}" />
            </Grid>
          </Border>

          <Border Style="{DynamicResource DbCard}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Style="{DynamicResource DbMetricLabel}" Text="Last tick" Margin="0,0,0,2" />
                <TextBlock Style="{DynamicResource DbSubtitle}" Text="Processing duration" />
              </StackPanel>
              <TextBlock Grid.Column="1"
                         Style="{DynamicResource DbSectionTitle}"
                         FontFamily="Cascadia Mono, Consolas, monospace"
                         Text="{Binding LastTickMs, StringFormat={}{0:0.#} ms}" />
            </Grid>
          </Border>
        </StackPanel>

        <Border Style="{DynamicResource DbBadgeAccent}"
                HorizontalAlignment="Stretch"
                Padding="12,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Runtime" Foreground="{DynamicResource DbAccent}" FontSize="11" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1"
                       FontFamily="Cascadia Mono, Consolas, monospace"
                       Foreground="{DynamicResource DbAccent}"
                       Text="{Binding Runtime}" />
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Border>
</rxui:ReactiveUserControl>
