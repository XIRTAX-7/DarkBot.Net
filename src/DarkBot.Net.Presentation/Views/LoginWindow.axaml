<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DarkBot.Net.Presentation.ViewModels"
        x:Class="DarkBot.Net.Presentation.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="DarkBot Login"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Border Padding="16">
    <StackPanel Spacing="10">
      <TextBlock FontSize="18" FontWeight="SemiBold" Text="DarkOrbit login" />
      <TextBlock Opacity="0.75" TextWrapping="Wrap"
                 Text="Sign in with username/password or paste a browser SID. User id is resolved from the spacemap preloader." />

      <TabControl SelectedIndex="{Binding SelectedTabIndex}">
        <TabItem Header="User &amp; password">
          <StackPanel Spacing="8" Margin="0,8,0,0">
            <TextBox PlaceholderText="Username" Text="{Binding Username}" IsEnabled="{Binding !IsBusy}" />
            <TextBox PlaceholderText="Password" Text="{Binding Password}" PasswordChar="●" IsEnabled="{Binding !IsBusy}" />
            <TextBox PlaceholderText="g-recaptcha-response (manual fallback)" Text="{Binding CaptchaToken}" IsEnabled="{Binding !IsBusy}" />
          </StackPanel>
        </TabItem>
        <TabItem Header="SID">
          <StackPanel Spacing="8" Margin="0,8,0,0">
            <TextBox PlaceholderText="Server (ru1, us1, …)" Text="{Binding Server}" IsEnabled="{Binding !IsBusy}" />
            <TextBox PlaceholderText="SID (dosid)" Text="{Binding Sid}" IsEnabled="{Binding !IsBusy}" />
          </StackPanel>
        </TabItem>
      </TabControl>

      <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="Cancel" IsCancel="True" Click="OnCancelClick" />
        <Button Content="Log in" IsDefault="True" Command="{Binding LoginCommand}" IsEnabled="{Binding !IsBusy}" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
