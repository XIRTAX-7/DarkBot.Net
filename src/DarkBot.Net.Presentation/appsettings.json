{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "DarkBot.Net.Infrastructure.Auth": "Debug",
        "DarkBot.Net.Infrastructure.Auth": "Debug",
        "DarkBot.Net.Application": "Debug",
        "DarkBot.Net.Plugins": "Information",
        "DarkBot.Net.Presentation": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/darkbot-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "DarkBot": {
    "LibPath": "./lib",
    "PluginsPath": "./plugins",
    "VerifierPath": "./lib/verifier.jar",
    "VerifierPort": 8091,
    "ProfilesPath": "./configs",
    "VerifierDevBypass": false,
    "BackpageSidecarPath": "./sidecars/backpage/dark_backpage.exe",
    "BackpageSidecarMinVersion": "1.3.0",
    "LogPath": "./logs/darkbot-.log",
    "BrowserApi": "FridaClient",
    "FridaApiPort": 44570,
    "ControlPort": 44568,
    "PacketPort": 44569,
    "EnablePacketBridge": true,
    "DarkorbitClientPath": "",
    "GameWidth": 1280,
    "GameHeight": 720,
    "Use3D": false,
    "UseProxy": false,
    "ForceGameLanguage": false
  }
}
