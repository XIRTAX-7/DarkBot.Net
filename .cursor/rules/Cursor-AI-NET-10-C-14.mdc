## Возможности C# 14 — использовать активно

```csharp
// ✅ Primary constructors
public class OrderService(IOrderRepository repository, ILogger<OrderService> logger)
{
    public async Task<Order> GetByIdAsync(Guid id, CancellationToken ct = default)
    {
        var order = await repository.GetByIdAsync(id, ct)
            ?? throw new NotFoundException($"Заказ {id} не найден");
        return order;
    }
}

// ✅ Collection expressions
int[] numbers = [1, 2, 3, 4, 5];
List<string> names = ["Alice", "Bob"];
Span<int> span = [..numbers, 6, 7];

// ✅ Pattern matching (расширенный)
var description = order.Status switch
{
    OrderStatus.Pending => "Ожидает обработки",
    OrderStatus.Processing => "В обработке",
    OrderStatus.Completed => "Завершён",
    _ => "Неизвестный статус"
};

// ✅ Record types для DTO/Value Objects
public record CreateOrderRequest(Guid CustomerId, IReadOnlyList<OrderItem> Items);
public record OrderId(Guid Value);

// ✅ Required members
public class UserProfile
{
    public required string Email { get; init; }
    public required string Name { get; init; }
    public string? Bio { get; init; }
}

// ✅ Raw string literals
var json = """
    {
        "key": "value"
    }
    """;

// ✅ Interceptors (C# 14)
// ✅ Params collections
// ✅ Inline arrays (где уместно)
```

