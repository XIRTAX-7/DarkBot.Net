## Entity Framework Core

```csharp
// ✅ Fluent API в отдельных IEntityTypeConfiguration<T>
public class OrderConfiguration : IEntityTypeConfiguration<Order>
{
    public void Configure(EntityTypeBuilder<Order> builder)
    {
        builder.HasKey(o => o.Id);
        builder.Property(o => o.Id)
            .HasConversion(id => id.Value, value => new OrderId(value));
        builder.OwnsOne(o => o.Address);
        builder.HasMany(o => o.Items).WithOne().HasForeignKey("OrderId");
    }
}

// ✅ AsNoTracking для read-only запросов
// ✅ Проекции через Select для DTO
// ✅ Не выставлять IQueryable за пределы репозитория
```

