## Асинхронное программирование

```csharp
// ✅ Всегда async/await, никогда .Result или .Wait()
// ✅ CancellationToken везде где есть I/O
// ✅ ConfigureAwait(false) в библиотечном коде

public async Task<IReadOnlyList<Product>> GetProductsAsync(
    ProductFilter filter,
    CancellationToken cancellationToken = default)
{
    return await dbContext.Products
        .Where(p => p.IsActive)
        .OrderBy(p => p.Name)
        .ToListAsync(cancellationToken)
        .ConfigureAwait(false);
}

// ✅ IAsyncEnumerable для потоков данных
public async IAsyncEnumerable<LogEntry> StreamLogsAsync(
    [EnumeratorCancellation] CancellationToken ct = default)
{
    await foreach (var entry in logSource.ReadAsync(ct))
        yield return entry;
}
```

