<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Controls.ConfigCollectSectionControl"
             x:TypeArguments="vm:ConfigTreeViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
             xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="600"
             Background="{DynamicResource ApplicationBackgroundBrush}"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}">

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
    <StackPanel>
      <ui:CardControl Margin="0,0,0,8"
                      Icon="{ui:SymbolIcon Shield24}">
        <ui:CardControl.Header>
          <ui:TextBlock FontTypography="Body"
                        Text="Держаться подальше от врагов"
                        TextWrapping="Wrap" />
        </ui:CardControl.Header>
        <ui:ToggleSwitch IsChecked="{Binding StayAwayFromEnemies}" />
      </ui:CardControl>

      <ui:CardControl Margin="0,0,0,8"
                      Icon="{ui:SymbolIcon EyeOff24}">
        <ui:CardControl.Header>
          <ui:TextBlock FontTypography="Body"
                        Text="Автоиспользование невидимости"
                        TextWrapping="Wrap" />
        </ui:CardControl.Header>
        <ui:ToggleSwitch IsChecked="{Binding AutoCloak}" />
      </ui:CardControl>

      <ui:CardControl Margin="0,0,0,8"
                      Icon="{ui:SymbolIcon Keyboard24}">
        <ui:CardControl.Header>
          <ui:TextBlock FontTypography="Body"
                        Text="Кнопка использования невидимости"
                        TextWrapping="Wrap" />
        </ui:CardControl.Header>
        <ui:TextBox Width="72"
                    MaxLength="1"
                    HorizontalContentAlignment="Center"
                    Text="{Binding AutoCloakKey, UpdateSourceTrigger=PropertyChanged}" />
      </ui:CardControl>

      <ui:CardControl Margin="0,0,0,8"
                      Icon="{ui:SymbolIcon Target24}">
        <ui:CardControl.Header>
          <StackPanel>
            <ui:TextBlock FontTypography="Body"
                          Text="Собирать, когда радиус убийства" />
            <ui:TextBlock FontTypography="Caption"
                          Appearance="Secondary"
                          Text="Радиус сбора ресурсов при убийстве NPC"
                          TextWrapping="Wrap" />
          </StackPanel>
        </ui:CardControl.Header>
        <ui:NumberBox Value="{Binding CollectRadius}"
                      Minimum="0"
                      Maximum="10000"
                      SpinButtonPlacementMode="Compact"
                      SmallChange="50"
                      LargeChange="200"
                      Width="120" />
      </ui:CardControl>

      <ui:CardControl Margin="0,0,0,8"
                      Icon="{ui:SymbolIcon BoxDismiss24}">
        <ui:CardControl.Header>
          <StackPanel>
            <ui:TextBlock FontTypography="Body"
                          Text="Игнорировать чужие коробки" />
            <ui:TextBlock FontTypography="Caption"
                          Appearance="Secondary"
                          Text="Игнорировать коробки, которые собираются другими игроками"
                          TextWrapping="Wrap" />
          </StackPanel>
        </ui:CardControl.Header>
        <ui:ToggleSwitch IsChecked="{Binding IgnoreContestedBoxes}" />
      </ui:CardControl>

      <ui:Card Margin="0,16,0,0" Padding="16">
        <StackPanel>
          <ui:TextBlock FontTypography="Subtitle" Text="Ресурсы" Margin="0,0,0,4" />
          <ui:TextBlock FontTypography="Caption"
                        Appearance="Secondary"
                        Text="Коробки или другие ресурсы, которые бот видел"
                        Margin="0,0,0,12" />

          <ui:TextBox Margin="0,0,0,12"
                      PlaceholderText="Поиск"
                      Icon="{ui:SymbolIcon Search24}"
                      Text="{Binding BoxSearchFilter, UpdateSourceTrigger=PropertyChanged}" />

          <ui:DataGrid ItemsSource="{Binding FilteredBoxes}"
                       AutoGenerateColumns="False"
                       CanUserAddRows="False"
                       CanUserDeleteRows="False"
                       CanUserReorderColumns="False"
                       CanUserResizeRows="False"
                       HeadersVisibility="Column"
                       GridLinesVisibility="Horizontal"
                       MinHeight="240">
            <ui:DataGrid.Columns>
              <DataGridTextColumn Header="Ресурс"
                                  Binding="{Binding Name}"
                                  IsReadOnly="True"
                                  Width="*" />
              <DataGridTextColumn Header="Ожидание (ms)"
                                  Binding="{Binding WaitTime, UpdateSourceTrigger=PropertyChanged}"
                                  Width="120" />
              <DataGridCheckBoxColumn Header="Сбор"
                                      Binding="{Binding Collect, UpdateSourceTrigger=PropertyChanged}"
                                      Width="72" />
              <DataGridTextColumn Header="Приоритет"
                                  Binding="{Binding Priority, UpdateSourceTrigger=PropertyChanged}"
                                  Width="90" />
            </ui:DataGrid.Columns>
          </ui:DataGrid>
        </StackPanel>
      </ui:Card>
    </StackPanel>
  </ScrollViewer>
</rxui:ReactiveUserControl>
