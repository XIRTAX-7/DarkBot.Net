<rxui:ReactiveUserControl x:Class="DarkBot.Net.Presentation.Views.Main.MainView"
        x:TypeArguments="vm:MainWindowViewModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rxui="clr-namespace:ReactiveUI;assembly=ReactiveUI.Wpf"
        xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels.Main"
        xmlns:loc="clr-namespace:DarkBot.Net.Presentation.Resources"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:mainControls="clr-namespace:DarkBot.Net.Presentation.Controls.Main"
        xmlns:mapCanvas="clr-namespace:DarkBot.Net.Presentation.Controls.Main.MapCanvas"
        mc:Ignorable="d"
        xml:lang="ru-RU"
        d:DesignWidth="1280"
        d:DesignHeight="820">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/DarkBot.Net.Presentation;component/Assets/Styles/WpfUiResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid Style="{StaticResource WpfUiViewHostGrid}" Margin="24,16,24,24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <ui:Card Grid.Row="0" Margin="0,0,0,16" Padding="12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ui:Button x:Name="ToggleBotButton"
                   Grid.Column="0"
                   Appearance="Primary"
                   Margin="0,0,8,0"
                   Content="{Binding RunButtonText}" />

        <ui:Button x:Name="OpenConfigButton"
                   Grid.Column="1"
                   Appearance="Secondary"
                   Margin="0,0,8,0"
                   Content="{x:Static loc:UiStrings.Main_ConfigButton}" />

        <ui:Button x:Name="OpenLoginButton"
                   Grid.Column="2"
                   Appearance="Transparent"
                   Margin="0,0,8,0"
                   Content="{x:Static loc:UiStrings.Main_LoginButton}" />

        <ui:Button x:Name="RestartClientButton"
                   Grid.Column="3"
                   Appearance="Transparent"
                   Margin="0,0,8,0"
                   ToolTip="{x:Static loc:UiStrings.Main_RestartClientTooltip}">
          <ui:Button.Icon>
            <ui:SymbolIcon Symbol="ArrowClockwise24" />
          </ui:Button.Icon>
        </ui:Button>

        <ui:InfoBadge Grid.Column="4"
                      Margin="8,0"
                      Value="{Binding StatusLine}"
                      VerticalAlignment="Center" />

        <ui:TextBlock Grid.Column="5"
                      FontTypography="Caption"
                      Appearance="Secondary"
                      VerticalAlignment="Center"
                      Text="{x:Static loc:UiStrings.Main_PhaseLabel}" />
      </Grid>
    </ui:Card>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="280" />
      </Grid.ColumnDefinitions>

      <ui:Card Grid.Column="0" Margin="0,0,16,0" Padding="0">
        <Border MinHeight="620" Style="{StaticResource WpfUiControlSurfaceBorder}">
          <mapCanvas:MapCanvasControl x:Name="MapCanvas"
                                     Snapshot="{Binding Snapshot}" />
        </Border>
      </ui:Card>

      <mainControls:StatsPanelControl Grid.Column="1"
                                  x:Name="StatsPanel" />
    </Grid>
  </Grid>
</rxui:ReactiveUserControl>
