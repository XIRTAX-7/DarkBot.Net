<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DarkBot.Net.Presentation.App"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme>
            <FluentTheme.Palettes>
                <ColorPaletteResources x:Key="Dark"
                                       Accent="#6D5DF6"
                                       RegionColor="#0A0D16" />
                <ColorPaletteResources x:Key="Light"
                                       Accent="#5B5CE2"
                                       RegionColor="#F4F7FB" />
            </FluentTheme.Palettes>
        </FluentTheme>

        <StyleInclude Source="avares://DarkBot.Net.Presentation/Assets/Styles/DarkBotControls.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ImageBrush x:Key="DbShellBackgroundImage"
                        Source="avares://DarkBot.Net.Presentation/Assets/backgrounds/nebula.png"
                        Stretch="UniformToFill"
                        AlignmentX="Center"
                        AlignmentY="Center" />

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="DbAppBackground" Color="#0A0D16" />
                    <SolidColorBrush x:Key="DbShellBackground" Color="#0D1220" />
                    <SolidColorBrush x:Key="DbSurface" Color="#101727" Opacity="0.96" />
                    <SolidColorBrush x:Key="DbSurfaceAlt" Color="#151D31" />
                    <SolidColorBrush x:Key="DbSurfaceSoft" Color="#111827" />
                    <SolidColorBrush x:Key="DbSurfaceElevated" Color="#172033" />
                    <SolidColorBrush x:Key="DbBorder" Color="#243047" />
                    <SolidColorBrush x:Key="DbBorderStrong" Color="#3B4A67" />
                    <SolidColorBrush x:Key="DbTextPrimary" Color="#F4F7FB" />
                    <SolidColorBrush x:Key="DbTextSecondary" Color="#9AA7BC" />
                    <SolidColorBrush x:Key="DbTextMuted" Color="#68758B" />
                    <SolidColorBrush x:Key="DbAccent" Color="#8B7CFF" />
                    <SolidColorBrush x:Key="DbAccentSoft" Color="#6D5DF6" Opacity="0.16" />
                    <SolidColorBrush x:Key="DbAccentStrong" Color="#6D5DF6" />
                    <SolidColorBrush x:Key="DbAccentForeground" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="DbSuccess" Color="#35D39B" />
                    <SolidColorBrush x:Key="DbSuccessSoft" Color="#10B981" Opacity="0.14" />
                    <SolidColorBrush x:Key="DbWarning" Color="#F7C948" />
                    <SolidColorBrush x:Key="DbWarningSoft" Color="#F59E0B" Opacity="0.14" />
                    <SolidColorBrush x:Key="DbDanger" Color="#FB7185" />
                    <SolidColorBrush x:Key="DbDangerSoft" Color="#F43F5E" Opacity="0.14" />
                    <SolidColorBrush x:Key="DbMapBackground" Color="#070A12" />
                    <SolidColorBrush x:Key="DbMapGrid" Color="#1A2440" />
                    <SolidColorBrush x:Key="DbTopBarBackground" Color="#111827" Opacity="0.94" />
                    <SolidColorBrush x:Key="DbTopBarBorder" Color="#253149" />
                    <SolidColorBrush x:Key="DbInputBackground" Color="#0D1424" />
                    <SolidColorBrush x:Key="DbInputBorder" Color="#28354D" />
                    <SolidColorBrush x:Key="DbInputForeground" Color="#F4F7FB" />
                    <SolidColorBrush x:Key="DbTreeItemHover" Color="#19243A" />
                    <SolidColorBrush x:Key="DbTreeItemSelected" Color="#6D5DF6" Opacity="0.14" />
                    <SolidColorBrush x:Key="DbStatTileBackground" Color="#131C2E" />
                    <SolidColorBrush x:Key="DbStatTileBorder" Color="#273650" />
                    <LinearGradientBrush x:Key="DbHeroGradient" StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#1A1745" Offset="0" />
                        <GradientStop Color="#172C4C" Offset="0.58" />
                        <GradientStop Color="#0E1F32" Offset="1" />
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="DbAccentGradientHorizontal" StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Color="#6D5DF6" Offset="0" />
                        <GradientStop Color="#2DD4BF" Offset="1" />
                    </LinearGradientBrush>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="DbAppBackground" Color="#F4F7FB" />
                    <SolidColorBrush x:Key="DbShellBackground" Color="#EDF2F8" />
                    <SolidColorBrush x:Key="DbSurface" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="DbSurfaceAlt" Color="#F2F5FA" />
                    <SolidColorBrush x:Key="DbSurfaceSoft" Color="#F8FAFD" />
                    <SolidColorBrush x:Key="DbSurfaceElevated" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="DbBorder" Color="#DCE4EF" />
                    <SolidColorBrush x:Key="DbBorderStrong" Color="#B8C6D9" />
                    <SolidColorBrush x:Key="DbTextPrimary" Color="#101828" />
                    <SolidColorBrush x:Key="DbTextSecondary" Color="#526174" />
                    <SolidColorBrush x:Key="DbTextMuted" Color="#8896AA" />
                    <SolidColorBrush x:Key="DbAccent" Color="#5B5CE2" />
                    <SolidColorBrush x:Key="DbAccentSoft" Color="#5B5CE2" Opacity="0.10" />
                    <SolidColorBrush x:Key="DbAccentStrong" Color="#494AC8" />
                    <SolidColorBrush x:Key="DbAccentForeground" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="DbSuccess" Color="#059669" />
                    <SolidColorBrush x:Key="DbSuccessSoft" Color="#10B981" Opacity="0.10" />
                    <SolidColorBrush x:Key="DbWarning" Color="#C27803" />
                    <SolidColorBrush x:Key="DbWarningSoft" Color="#F59E0B" Opacity="0.12" />
                    <SolidColorBrush x:Key="DbDanger" Color="#E11D48" />
                    <SolidColorBrush x:Key="DbDangerSoft" Color="#F43F5E" Opacity="0.10" />
                    <SolidColorBrush x:Key="DbMapBackground" Color="#111827" />
                    <SolidColorBrush x:Key="DbMapGrid" Color="#D4DEEC" />
                    <SolidColorBrush x:Key="DbTopBarBackground" Color="#FFFFFF" Opacity="0.94" />
                    <SolidColorBrush x:Key="DbTopBarBorder" Color="#DCE4EF" />
                    <SolidColorBrush x:Key="DbInputBackground" Color="#F8FAFD" />
                    <SolidColorBrush x:Key="DbInputBorder" Color="#D3DDEA" />
                    <SolidColorBrush x:Key="DbInputForeground" Color="#101828" />
                    <SolidColorBrush x:Key="DbTreeItemHover" Color="#EDF2F8" />
                    <SolidColorBrush x:Key="DbTreeItemSelected" Color="#5B5CE2" Opacity="0.10" />
                    <SolidColorBrush x:Key="DbStatTileBackground" Color="#F8FAFD" />
                    <SolidColorBrush x:Key="DbStatTileBorder" Color="#DCE4EF" />
                    <LinearGradientBrush x:Key="DbHeroGradient" StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#5B5CE2" Offset="0" />
                        <GradientStop Color="#4F8CEB" Offset="0.55" />
                        <GradientStop Color="#2DD4BF" Offset="1" />
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="DbAccentGradientHorizontal" StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Color="#5B5CE2" Offset="0" />
                        <GradientStop Color="#14B8A6" Offset="1" />
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>