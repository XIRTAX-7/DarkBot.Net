<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DarkBot.Net.Ui.ViewModels"
             x:Class="DarkBot.Net.Ui.Controls.PluginPanelControl"
             x:Name="Root"
             x:DataType="vm:PluginPanelViewModel">
  <StackPanel Spacing="8" Margin="8">
    <DockPanel>
      <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" FontSize="16" Text="Plugins" />
      <Button DockPanel.Dock="Right" Content="Reload" Command="{Binding ReloadPluginsCommand}" />
    </DockPanel>
    <TextBlock Text="{Binding Status}" TextWrapping="Wrap" />
    <ListBox ItemsSource="{Binding Features}" MinHeight="180">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:PluginFeatureItem">
          <StackPanel Spacing="2" Margin="0,4">
            <DockPanel>
              <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
              <TextBlock DockPanel.Dock="Right" Opacity="0.7" Text="{Binding Kind}" />
            </DockPanel>
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="11" Opacity="0.8" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock FontSize="10" Opacity="0.6" Text="{Binding PluginName}" />
              <TextBlock FontSize="10" Text="{Binding Enabled, StringFormat=Enabled: {0}}" />
              <Button Content="Use module"
                      IsVisible="{Binding IsModule}"
                      Command="{Binding #Root.((vm:PluginPanelViewModel)DataContext).SetActiveModuleCommand}"
                      CommandParameter="{Binding}" />
              <TextBlock FontSize="10"
                         Foreground="Green"
                         IsVisible="{Binding IsActiveModule}"
                         Text="(active)" />
            </StackPanel>
            <TextBlock IsVisible="{Binding LoadError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="OrangeRed"
                       FontSize="10"
                       Text="{Binding LoadError}" />
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </StackPanel>
</UserControl>
