<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:converters="clr-namespace:DarkBot.Net.Presentation.Converters">
  <!-- Как в Wpf.Ui.ControlsDictionary / ApplicationThemeManager — pack URI для design-time -->
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Theme/Dark.xaml" />
    <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Wpf.Ui.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
  <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

  <LinearGradientBrush x:Key="WpfUiPremiumCommandBarBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#262B36" Offset="0" />
    <GradientStop Color="#181B22" Offset="0.55" />
    <GradientStop Color="#111318" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="WpfUiPremiumBrandBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#3B82F6" Offset="0" />
    <GradientStop Color="#7C3AED" Offset="1" />
  </LinearGradientBrush>

  <!-- NavigationView Page: без явного фона WPF рисует белый Page поверх Mica -->
  <Style TargetType="{x:Type Page}">
    <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
  </Style>

  <Style TargetType="{x:Type ScrollViewer}">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <!-- Корневой Grid для Page / UserControl / Window content -->
  <Style x:Key="WpfUiViewHostGrid" TargetType="Grid">
    <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
  </Style>

  <!-- Встроенная поверхность (карта, превью) -->
  <Style x:Key="WpfUiControlSurfaceBorder" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style x:Key="MainSurfaceBorder" TargetType="{x:Type Border}">
    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style x:Key="MainStatusPillBorder"
         TargetType="{x:Type Border}"
         BasedOn="{StaticResource MainSurfaceBorder}">
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
  </Style>

  <Style x:Key="MainStatusDot" TargetType="{x:Type Ellipse}">
    <Setter Property="Width" Value="8" />
    <Setter Property="Height" Value="8" />
    <Setter Property="Fill" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style x:Key="MainCommandBarBorder"
         TargetType="{x:Type Border}"
         BasedOn="{StaticResource MainSurfaceBorder}">
    <Setter Property="Background" Value="{StaticResource WpfUiPremiumCommandBarBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style x:Key="MainBrandMarkBorder" TargetType="{x:Type Border}">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Background" Value="{StaticResource WpfUiPremiumBrandBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style x:Key="MainCommandButton"
         TargetType="{x:Type ui:Button}"
         BasedOn="{StaticResource {x:Type ui:Button}}">
    <Setter Property="Width" Value="96" />
    <Setter Property="Height" Value="36" />
    <Setter Property="MinWidth" Value="96" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="Margin" Value="0,0,6,0" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style x:Key="MainCommandButtonLast"
         TargetType="{x:Type ui:Button}"
         BasedOn="{StaticResource MainCommandButton}">
    <Setter Property="Margin" Value="0" />
  </Style>

  <Style x:Key="MainToolbarComboBox"
         TargetType="{x:Type ComboBox}"
         BasedOn="{StaticResource {x:Type ComboBox}}">
    <Setter Property="Width" Value="128" />
    <Setter Property="Height" Value="36" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style x:Key="MainMetricCaption" TargetType="{x:Type ui:TextBlock}">
    <Setter Property="FontTypography" Value="Caption" />
    <Setter Property="Appearance" Value="Secondary" />
  </Style>

  <Style x:Key="MainMetricValue" TargetType="{x:Type ui:TextBlock}">
    <Setter Property="FontTypography" Value="Subtitle" />
    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
  </Style>

  <Style x:Key="MainBottomPanelTitle" TargetType="{x:Type ui:TextBlock}">
    <Setter Property="FontTypography" Value="BodyStrong" />
  </Style>

  <Style x:Key="MainCompactSurfaceBorder"
         TargetType="{x:Type Border}"
         BasedOn="{StaticResource MainSurfaceBorder}">
    <Setter Property="Padding" Value="8" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <Style x:Key="MainCompactMetricCaption" TargetType="{x:Type ui:TextBlock}">
    <Setter Property="FontTypography" Value="Caption" />
    <Setter Property="Appearance" Value="Secondary" />
  </Style>

  <Style x:Key="MainCompactMetricValue" TargetType="{x:Type ui:TextBlock}">
    <Setter Property="FontTypography" Value="Body" />
    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
  </Style>

  <Style x:Key="MainCompactStatusPillBorder"
         TargetType="{x:Type Border}"
         BasedOn="{StaticResource MainCompactSurfaceBorder}">
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
  </Style>

  <Style x:Key="MainCompactSectionLabel" TargetType="{x:Type ui:TextBlock}">
    <Setter Property="FontTypography" Value="Caption" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <LinearGradientBrush x:Key="TitleBarDiagnosticsSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#332D3440" Offset="0" />
    <GradientStop Color="#221A1D26" Offset="0.58" />
    <GradientStop Color="#30222A35" Offset="1" />
  </LinearGradientBrush>

  <Style x:Key="TitleBarDiagnosticsBorder" TargetType="{x:Type Border}">
    <Setter Property="Background" Value="{StaticResource TitleBarDiagnosticsSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Padding" Value="5" />
    <Setter Property="Margin" Value="0,0,8,0" />
    <Setter Property="MinHeight" Value="38" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect BlurRadius="14"
                          ShadowDepth="0"
                          Color="#66000000"
                          Opacity="0.18" />
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="TitleBarDiagnosticMetricPanel" TargetType="{x:Type StackPanel}">
    <Setter Property="Orientation" Value="Horizontal" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style x:Key="TitleBarDiagnosticMetricPill" TargetType="{x:Type Border}">
    <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="13" />
    <Setter Property="Padding" Value="7,4,8,4" />
    <Setter Property="Margin" Value="0,0,4,0" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style x:Key="TitleBarDiagnosticMetricPillLast"
         TargetType="{x:Type Border}"
         BasedOn="{StaticResource TitleBarDiagnosticMetricPill}">
    <Setter Property="Margin" Value="0" />
  </Style>

  <Style x:Key="TitleBarDiagnosticIconSurface" TargetType="{x:Type Border}">
    <Setter Property="Width" Value="22" />
    <Setter Property="Height" Value="22" />
    <Setter Property="CornerRadius" Value="11" />
    <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    <Setter Property="Margin" Value="0,0,6,0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style x:Key="TitleBarDiagnosticIcon" TargetType="{x:Type ui:SymbolIcon}">
    <Setter Property="Width" Value="12" />
    <Setter Property="Height" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style x:Key="TitleBarDiagnosticCaption" TargetType="{x:Type ui:TextBlock}">
    <Setter Property="FontTypography" Value="Caption" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style x:Key="TitleBarDiagnosticValue" TargetType="{x:Type ui:TextBlock}">
    <Setter Property="FontTypography" Value="Caption" />
    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="TextAlignment" Value="Left" />
    <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
  </Style>

  <Style x:Key="WpfUiDivider" TargetType="Separator">
    <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
  </Style>

  <Style x:Key="WpfUiAccentCaption" TargetType="{x:Type ui:TextBlock}">
    <Setter Property="FontTypography" Value="Caption" />
    <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
  </Style>

  <Style x:Key="WpfUiAccentMonospaceCaption"
         TargetType="{x:Type ui:TextBlock}"
         BasedOn="{StaticResource WpfUiAccentCaption}">
    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
  </Style>
</ResourceDictionary>
