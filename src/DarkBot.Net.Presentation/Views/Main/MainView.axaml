<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rxui="http://reactiveui.net"
        xmlns:controls="clr-namespace:DarkBot.Net.Presentation.Controls"
        xmlns:vm="clr-namespace:DarkBot.Net.Presentation.ViewModels"
        mc:Ignorable="d"
        x:Class="DarkBot.Net.Presentation.Views.Main.MainView"
        x:TypeArguments="vm:MainWindowViewModel"
        x:DataType="vm:MainWindowViewModel"
        Design.Width="1280"
        Design.Height="820">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Border Background="Transparent">
    <Grid RowDefinitions="Auto,*"
          RowSpacing="14"
          Margin="18">
      <Border Grid.Row="0" Classes="dbToolbar">
        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto"
              ColumnSpacing="10">
          <Button Grid.Column="0"
                  Classes="dbButton primary"
                  Command="{Binding ToggleBotCommand}"
                  Content="{Binding RunButtonText}" />

          <Button Grid.Column="1"
                  Classes="dbButton secondary"
                  Name="ConfigButton"
                  Content="Config" />

          <Button Grid.Column="2"
                  Classes="dbButton ghost"
                  Name="LoginButton"
                  Content="Login" />

          <Border Grid.Column="3"
                  Classes="dbBadge"
                  HorizontalAlignment="Stretch"
                  Margin="4,0"
                  Padding="12,6">
            <TextBlock Text="{Binding StatusLine}"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />
          </Border>

          <Border Grid.Column="4" Classes="dbBadge success">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Backpage" />
              <TextBlock Text="{Binding BackpageStatus}" />
            </StackPanel>
          </Border>

          <TextBlock Grid.Column="5"
                     Classes="dbCaption"
                     VerticalAlignment="Center"
                     Text="DarkBot.Net Phase 3" />
        </Grid>
      </Border>

      <Grid Grid.Row="1"
            ColumnDefinitions="*,280"
            ColumnSpacing="14">
        <Border Grid.Column="0" Classes="dbMapFrame">
          <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="dbMapTopBar">
              <Grid ColumnDefinitions="Auto,Auto,*"
                    ColumnSpacing="8">
                <TextBlock Classes="dbSectionTitle"
                           VerticalAlignment="Center"
                           Text="{Binding Snapshot.MapName}" />
                <TextBlock Grid.Column="1"
                           Classes="dbCaption dbMono"
                           VerticalAlignment="Center"
                           Text="{Binding Snapshot.MapId, StringFormat=({0})}" />
                <TextBlock Grid.Column="2"
                           Classes="dbCaption"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Text="{Binding GameStatusLine}"
                           TextTrimming="CharacterEllipsis" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="dbMapSurface">
              <controls:MapCanvasControl Name="MapCanvas"
                                         Snapshot="{Binding Snapshot}" />
            </Border>
          </Grid>
        </Border>

        <controls:StatsPanelControl Grid.Column="1"
                                    Name="StatsPanel" />
      </Grid>
    </Grid>
  </Border>
</rxui:ReactiveUserControl>
